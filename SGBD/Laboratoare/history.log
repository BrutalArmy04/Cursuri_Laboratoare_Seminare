fc183c71-9ac9-457a-80a6-0bba32d11281:1766420053407:42:S:create table dept_sro as select * from dept_ari;
7472dd31-b46c-41e0-9e56-bc5d10051db6:1766420087886:118:S:CREATE OR REPLACE TRIGGER trg_limit_angajati_dept\n    AFTER INSERT OR UPDATE OF department_id ON emp_sro\nDECLARE\n    -- Cursor pentru a identifica departamentele care depășesc limita\n    CURSOR c_dept_violation IS\n        SELECT department_id, COUNT(*) as nr_angajati\n        FROM emp_sro\n        GROUP BY department_id\n        HAVING COUNT(*) > 45;\n        \n    v_dept_id emp_sro.department_id%TYPE;\n    v_count   NUMBER;\nBEGIN\n    -- Iterăm prin departamentele care au încălcat regula\n    FOR rec IN c_dept_violation LOOP\n        RAISE_APPLICATION_ERROR(-20001, \n            'Eroare: Departamentul ' || rec.department_id || \n            ' are deja ' || rec.nr_angajati || \n            ' angajati. Limita maxima este de 45.');\n    END LOOP;\nEND;\n/
