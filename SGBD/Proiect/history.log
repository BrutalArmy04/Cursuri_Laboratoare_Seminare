05af199c-1a62-496c-8c85-780c24428d44:1767617391397:21:F:CREATE OR REPLACE PROCEDURE analiza_jocuri_finalizate IS\n    -- Cursor 1: Independent (Itereaza jocurile finalizate)\n    CURSOR c_jocuri IS\n        SELECT id_joc, status \n        FROM JOC \n        WHERE status = 'FINALIZAT';\n        \n    -- Cursor 2: Parametrizat si Dependent (Depinde de id_joc din primul cursor)\n    CURSOR c_detalii_jucatori (p_id_joc NUMBER) IS\n        SELECT j.nume_utilizator, c.nume_caracter\n        FROM SELECTIE_CARACTER sc\n        JOIN JUCATOR j ON sc.id_jucator = j.id_jucator\n        JOIN CARACTER c ON sc.id_caracter = c.id_caracter\n        JOIN TURA t ON sc.id_tura = t.id_tura\n        WHERE t.id_joc = p_id_joc\n        AND t.id_tura = (SELECT MIN(id_tura) FROM TURA WHERE id_joc = p_id_joc); -- Doar prima tura\n\n    -- Variabile pentru fetch\n    v_id_joc_curent JOC.id_joc%TYPE;\n    v_status JOC.status%TYPE;\n    \n    v_nume_user JUCATOR.nume_utilizator%TYPE;\n    v_nume_caracter CARACTER.nume_caracter%TYPE;\n\nBEGIN\n    -- Deschidem primul cursor\n    OPEN c_jocuri;\n    LOOP\n        FETCH c_jocuri INTO v_id_joc_curent, v_status;\n        EXIT WHEN c_jocuri%NOTFOUND;\n        \n        DBMS_OUTPUT.PUT_LINE('-------------------------------------------');\n        DBMS_OUTPUT.PUT_LINE('Analiza Jocului #' || v_id_joc_curent || ' (Status: ' || v_status || ')');\n        DBMS_OUTPUT.PUT_LINE('Jucatori si caracterele de start:');\n        \n        -- Deschidem al doilea cursor, pasand valoarea din primul cursor ca parametru\n        OPEN c_detalii_jucatori(v_id_joc_curent);\n        LOOP\n            FETCH c_detalii_jucatori INTO v_nume_user, v_nume_caracter;\n            EXIT WHEN c_detalii_jucatori%NOTFOUND;\n            \n            DBMS_OUTPUT.PUT_LINE(' -> Jucator: ' || RPAD(v_nume_user, 15) || ' | Caracter Start: ' || v_nume_caracter);\n        END LOOP;\n        \n        -- Verificam daca nu au existat inregistrari in cursorul 2\n        IF c_detalii_jucatori%ROWCOUNT = 0 THEN\n            DBMS_OUTPUT.PUT_LINE(' -> Nu exista date despre prima tura pentru acest joc.');\n        END IF;\n        \n        CLOSE c_detalii_jucatori; -- Inchidem cursorul parametrizat\n        \n    END LOOP;\n    CLOSE c_jocuri; -- Inchidem cursorul principal\n\nEXCEPTION\n    WHEN OTHERS THEN\n        IF c_jocuri%ISOPEN THEN CLOSE c_jocuri; END IF;\n        IF c_detalii_jucatori%ISOPEN THEN CLOSE c_detalii_jucatori; END IF;\n        RAISE_APPLICATION_ERROR(-20003, 'Eroare in analiza jocurilor: ' || SQLERRM);\nEND analiza_jocuri_finalizate;\n/
d0e157c7-443d-4ba7-872c-d89da5664f33:1767617391505:28:F:BEGIN\n    analiza_jocuri_finalizate;\nEND;\n/
acc610ee-5c0a-476c-be3d-233afc171e56:1767618263967:19:F:CREATE OR REPLACE PROCEDURE analiza_jocuri_finalizate IS\n    CURSOR c_jocuri IS\n        SELECT id_joc, status \n        FROM JOC \n        WHERE status = 'FINALIZAT';\n        \n    CURSOR c_detalii_jucatori (p_id_joc NUMBER) IS\n        SELECT j.nume_utilizator, c.nume_caracter\n        FROM SELECTIE_CARACTER sc\n        JOIN JUCATOR j ON sc.id_jucator = j.id_jucator\n        JOIN CARACTER c ON sc.id_caracter = c.id_caracter\n        JOIN TURA t ON sc.id_tura = t.id_tura\n        WHERE t.id_joc = p_id_joc\n        AND t.id_tura = (SELECT MIN(id_tura) FROM TURA WHERE id_joc = p_id_joc);\n\n    v_id_joc_curent JOC.id_joc%TYPE;\n    v_status JOC.status%TYPE;\n    \n    v_nume_user JUCATOR.nume_utilizator%TYPE;\n    v_nume_caracter CARACTER.nume_caracter%TYPE;\n\nBEGIN\n    OPEN c_jocuri;\n    LOOP\n        FETCH c_jocuri INTO v_id_joc_curent, v_status;\n        EXIT WHEN c_jocuri%NOTFOUND;\n        \n        DBMS_OUTPUT.PUT_LINE('-------------------------------------------');\n        DBMS_OUTPUT.PUT_LINE('Analiza Jocului #' || v_id_joc_curent || ' (Status: ' || v_status || ')');\n        DBMS_OUTPUT.PUT_LINE('Jucatori si caracterele de start:');\n        \n        OPEN c_detalii_jucatori(v_id_joc_curent);\n        LOOP\n            FETCH c_detalii_jucatori INTO v_nume_user, v_nume_caracter;\n            EXIT WHEN c_detalii_jucatori%NOTFOUND;\n            \n            DBMS_OUTPUT.PUT_LINE(' -> Jucator: ' || v_nume_user || ' | Caracter Start: ' || v_nume_caracter);\n        END LOOP;\n        \n        IF c_detalii_jucatori%ROWCOUNT = 0 THEN\n            DBMS_OUTPUT.PUT_LINE(' -> Nu exista date despre prima tura pentru acest joc.');\n        END IF;\n        \n        CLOSE c_detalii_jucatori; \n        \n    END LOOP;\n    CLOSE c_jocuri; \n\nEXCEPTION\n    WHEN OTHERS THEN\n        IF c_jocuri%ISOPEN THEN CLOSE c_jocuri; END IF;\n        IF c_detalii_jucatori%ISOPEN THEN CLOSE c_detalii_jucatori; END IF;\n        RAISE_APPLICATION_ERROR(-20003, 'Eroare in analiza jocurilor: ' || SQLERRM);\nEND analiza_jocuri_finalizate;\n/
fa33fe6a-3803-4fba-bc0e-5e4d9c9a3aeb:1767618264073:6:F:BEGIN\n    analiza_jocuri_finalizate;\nEND;\n/
881e4da8-02de-4f91-bbf0-4c1855d07bb6:1767619259741:22:F:CREATE OR REPLACE FUNCTION get_cladire_jucator_carte (\n    p_nume_utilizator IN JUCATOR.nume_utilizator%TYPE,\n    p_id_carte        IN CARTE.id_carte%TYPE\n) \nRETURN NUMBER \nIS\n    v_id_cladire CLADIRE.id_cladire%TYPE;\nBEGIN\n    -- Selectam ID-ul cladirii facand JOIN intre 3 tabele:\n    -- JUCATOR -> ORAS -> CLADIRE\n    SELECT c.id_cladire\n    INTO v_id_cladire\n    FROM JUCATOR j\n    JOIN ORAS o ON j.id_jucator = o.id_jucator\n    JOIN CLADIRE c ON o.id_oras = c.id_oras\n    WHERE j.nume_utilizator = p_nume_utilizator\n      AND c.id_carte = p_id_carte;\n\n    RETURN v_id_cladire;\n\nEXCEPTION\n    WHEN NO_DATA_FOUND THEN\n        DBMS_OUTPUT.PUT_LINE('Exceptie: Jucatorul ' || p_nume_utilizator || \n                             ' nu are construita cartea cu ID ' || p_id_carte);\n        RETURN NULL; -- Sau putem returna -1 pentru a semnala eroarea in apelant\n        \n    WHEN TOO_MANY_ROWS THEN\n        DBMS_OUTPUT.PUT_LINE('Exceptie: Jucatorul ' || p_nume_utilizator || \n                             ' are mai multe cladiri de tipul cartii ' || p_id_carte);\n        RETURN NULL;\n        \n    WHEN OTHERS THEN\n        RAISE_APPLICATION_ERROR(-20002, 'Alta eroare: ' || SQLERRM);\nEND get_cladire_jucator_carte;\n/
8c436fbf-18d7-44cb-91a0-b690ff6cee8b:1767619259845:0:S:SET SERVEROUTPUT ON;
5f040b26-2a1e-47d0-a722-fb970d418241:1767619261034:20:F:DECLARE\n    v_rezultat NUMBER;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('--- CAZ 1: SUCCES (O singura linie) ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 2);\n    IF v_rezultat IS NOT NULL THEN\n        DBMS_OUTPUT.PUT_LINE('Rezultat: ID-ul cladirii este ' || v_rezultat);\n    END IF;\n    DBMS_OUTPUT.PUT_LINE('');\n\n    DBMS_OUTPUT.PUT_LINE('--- CAZ 2: TOO_MANY_ROWS (Mai multe cladiri identice) ---');\n    -- 'lupul_alb' are doua cladiri construite cu cartea ID 1 (Biserica)\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 1);\n    DBMS_OUTPUT.PUT_LINE('');\n\n    DBMS_OUTPUT.PUT_LINE('--- CAZ 3: NO_DATA_FOUND (Nu exista) ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 99);\n    DBMS_OUTPUT.PUT_LINE('');\nEND;\n/
ad20df67-7f34-44ba-b632-506d373dd221:1767619740343:16:F:DECLARE\n    v_rezultat NUMBER;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('--- Caz 1: SUCCES (O singura linie) ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 2);\n    IF v_rezultat IS NOT NULL THEN\n        DBMS_OUTPUT.PUT_LINE('Rezultat: ID-ul cladirii este ' || v_rezultat);\n    END IF;\n    DBMS_OUTPUT.PUT_LINE('');\n\n    DBMS_OUTPUT.PUT_LINE('--- Caz 2: TOO_MANY_ROWS ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 1);\n    DBMS_OUTPUT.PUT_LINE('');\n\n    DBMS_OUTPUT.PUT_LINE('--- Caz 3: NO_DATA_FOUND ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 99);\n    DBMS_OUTPUT.PUT_LINE('');\nEND;\n/
619f012a-f431-417c-942b-9fe13841d9be:1767621100120:45:F:DECLARE\n    v_rezultat NUMBER;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('--- Caz 1: SUCCES (O singura linie) ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 2);\n    IF v_rezultat IS NOT NULL THEN\n        DBMS_OUTPUT.PUT_LINE('Rezultat: ID-ul cladirii este ' || v_rezultat);\n    END IF;\n    DBMS_OUTPUT.PUT_LINE('');\n\n    --am adaugat aici, deoarece nu aveam cum sa ilustez too_many_rows\n    INSERT INTO CLADIRE VALUES (seq_cladire.NEXTVAL, 1, 1, 1);\n    COMMIT;\n\n    DBMS_OUTPUT.PUT_LINE('--- Caz 2: TOO_MANY_ROWS ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 1);\n    DBMS_OUTPUT.PUT_LINE('');\n\n    --sterg ce am adaugat mai sus\n    DELETE FROM CLADIRE \n    WHERE id_cladire = (\n    SELECT MAX(id_cladire) \n    FROM CLADIRE \n    WHERE id_oras = 1 AND id_carte = 1);\n    COMMIT;\n\n    DBMS_OUTPUT.PUT_LINE('--- Caz 3: NO_DATA_FOUND ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 99);\n    DBMS_OUTPUT.PUT_LINE('');\nEND;\n/
4730cdf7-bbd0-4315-8925-7d83e245a860:1767621484696:28:F:CREATE OR REPLACE FUNCTION get_cladire_jucator_carte (\n    p_nume_utilizator IN JUCATOR.nume_utilizator%TYPE,\n    p_id_carte        IN CARTE.id_carte%TYPE\n) \nRETURN NUMBER \nIS\n    v_id_cladire CLADIRE.id_cladire%TYPE;\nBEGIN\n    SELECT c.id_cladire\n    INTO v_id_cladire\n    FROM JUCATOR j\n    JOIN ORAS o ON j.id_jucator = o.id_jucator\n    JOIN CLADIRE c ON o.id_oras = c.id_oras\n    WHERE j.nume_utilizator = p_nume_utilizator\n      AND c.id_carte = p_id_carte;\n\n    RETURN v_id_cladire;\n\nEXCEPTION\n    WHEN NO_DATA_FOUND THEN\n        DBMS_OUTPUT.PUT_LINE('Exceptie: Jucatorul ' || p_nume_utilizator || \n                             ' nu are construita cartea cu ID ' || p_id_carte);\n        RETURN NULL; \n        \n    WHEN TOO_MANY_ROWS THEN\n        DBMS_OUTPUT.PUT_LINE('Exceptie: Jucatorul ' || p_nume_utilizator || \n                             ' are mai multe cladiri de tipul cartii ' || p_id_carte);\n        RETURN NULL;\n        \n    WHEN OTHERS THEN\n        RAISE_APPLICATION_ERROR(-20002, 'Alta eroare: ' || SQLERRM);\nEND get_cladire_jucator_carte;\n/
2a57e825-52a8-4132-b030-02dd894af9a7:1767621485757:7:F:DECLARE\n    v_rezultat NUMBER;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('--- Caz 1: SUCCES (O singura linie) ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 2);\n    IF v_rezultat IS NOT NULL THEN\n        DBMS_OUTPUT.PUT_LINE('Rezultat: ID-ul cladirii este ' || v_rezultat);\n    END IF;\n    DBMS_OUTPUT.PUT_LINE('');\n\n    --am adaugat aici, deoarece nu aveam cum sa ilustez too_many_rows\n    INSERT INTO CLADIRE VALUES (seq_cladire.NEXTVAL, 1, 1, 1);\n    COMMIT;\n\n    DBMS_OUTPUT.PUT_LINE('--- Caz 2: TOO_MANY_ROWS ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 1);\n    DBMS_OUTPUT.PUT_LINE('');\n\n    --sterg ce am adaugat mai sus\n    DELETE FROM CLADIRE \n    WHERE id_cladire = (\n    SELECT MAX(id_cladire) \n    FROM CLADIRE \n    WHERE id_oras = 1 AND id_carte = 1);\n    COMMIT;\n\n    DBMS_OUTPUT.PUT_LINE('--- Caz 3: NO_DATA_FOUND ---');\n    v_rezultat := get_cladire_jucator_carte('lupul_alb', 99);\n    DBMS_OUTPUT.PUT_LINE('');\nEND;\n/
d614fac6-3def-4869-85da-3ee02b2d0388:1767622990043:40:F:CREATE OR REPLACE PROCEDURE analiza_consum_resurse (\n    p_nume_utilizator IN JUCATOR.nume_utilizator%TYPE,\n    p_tip_carte       IN CARTE.tip_carte%TYPE\n) \nIS\n    v_total_resurse NUMBER := 0;\n    v_count_user    NUMBER;\nBEGIN\n    SELECT COUNT(*) INTO v_count_user \n    FROM JUCATOR \n    WHERE nume_utilizator = p_nume_utilizator;\n    \n    IF v_count_user = 0 THEN\n        RAISE_APPLICATION_ERROR(-20001, 'Jucatorul "' || p_nume_utilizator || '" nu exista in baza de date.');\n    END IF;\n\n    IF p_tip_carte NOT IN ('Negustoreasca', 'Boiereasca', 'Religioasa', 'Militara', 'Unica') THEN\n        RAISE_APPLICATION_ERROR(-20002, 'Tipul "' || p_tip_carte || '" nu este valid. Alegeti un tip corect.');\n    END IF;\n\n    SELECT NVL(SUM(f.cantitate_folosita), 0)\n    INTO v_total_resurse\n    FROM JUCATOR j\n    JOIN ORAS o ON j.id_jucator = o.id_jucator\n    JOIN CLADIRE cl ON o.id_oras = cl.id_oras\n    JOIN CARTE c ON cl.id_carte = c.id_carte\n    JOIN FOLOSESTE f ON cl.id_cladire = f.id_cladire\n    WHERE j.nume_utilizator = p_nume_utilizator\n      AND c.tip_carte = p_tip_carte;\n\n    DBMS_OUTPUT.PUT_LINE('Succes: Jucatorul ' || p_nume_utilizator || \n                         ' a consumat ' || v_total_resurse || \n                         ' resurse pentru cladirile de tip ' || p_tip_carte || '.');\n\n\nEXCEPTION\n    WHEN OTHERS THEN\n        IF SQLCODE BETWEEN -20999 AND -20000 THEN\n            RAISEș\n        ELSE\n            RAISE_APPLICATION_ERROR(-20003, 'Eroare interna SQL: ' || SQLERRM);\n        END IF;\nEND analiza_consum_resurse;\n/
3d77e8d8-5659-4128-a48a-665d358225d5:1767622991595:0:F:DECLARE\n    e_user_inexistent EXCEPTION;\n    PRAGMA EXCEPTION_INIT(e_user_inexistent, -20001);\n    \n    e_tip_invalid     EXCEPTION;\n    PRAGMA EXCEPTION_INIT(e_tip_invalid, -20002);\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 1: Apel cu jucator inexistent');\n    BEGIN\n        analiza_consum_resurse('fantoma', 'Religioasa');\n    EXCEPTION\n        WHEN e_user_inexistent THEN\n            DBMS_OUTPUT.PUT_LINE(' Prins eroare -20001: ' || SQLERRM);\n    END;\n\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 2: Apel cu tip de carte gresit');\n    BEGIN\n        analiza_consum_resurse('lupul_alb', 'Magica');\n    EXCEPTION\n        WHEN e_tip_invalid THEN\n            DBMS_OUTPUT.PUT_LINE(' Prins eroare -20002: ' || SQLERRM);\n    END;\n\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 3: Apel corect');\n    BEGIN\n        analiza_consum_resurse('lupul_alb', 'Religioasa');\n    EXCEPTION\n        WHEN OTHERS THEN\n            DBMS_OUTPUT.PUT_LINE(' -> Eroare neasteptata: ' || SQLERRM);\n    END;\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\nEND;\n/
b7ffe1c8-0d88-4d84-a205-48b2d77be069:1767623292237:34:F:CREATE OR REPLACE PROCEDURE analiza_consum_resurse (\n    p_nume_utilizator IN JUCATOR.nume_utilizator%TYPE,\n    p_tip_carte       IN CARTE.tip_carte%TYPE\n) \nIS\n    v_total_resurse NUMBER := 0;\n    v_count_user    NUMBER;\nBEGIN\n    SELECT COUNT(*) INTO v_count_user \n    FROM JUCATOR \n    WHERE nume_utilizator = p_nume_utilizator;\n    \n    IF v_count_user = 0 THEN\n        RAISE_APPLICATION_ERROR(-20001, 'Jucatorul "' || p_nume_utilizator || '" nu exista in baza de date.');\n    END IF;\n\n    IF p_tip_carte NOT IN ('Negustoreasca', 'Boiereasca', 'Religioasa', 'Militara', 'Unica') THEN\n        RAISE_APPLICATION_ERROR(-20002, 'Tipul "' || p_tip_carte || '" nu este valid. Alegeti un tip corect.');\n    END IF;\n\n    SELECT NVL(SUM(f.cantitate_folosita), 0)\n    INTO v_total_resurse\n    FROM JUCATOR j\n    JOIN ORAS o ON j.id_jucator = o.id_jucator\n    JOIN CLADIRE cl ON o.id_oras = cl.id_oras\n    JOIN CARTE c ON cl.id_carte = c.id_carte\n    JOIN FOLOSESTE f ON cl.id_cladire = f.id_cladire\n    WHERE j.nume_utilizator = p_nume_utilizator\n      AND c.tip_carte = p_tip_carte;\n\n    DBMS_OUTPUT.PUT_LINE('Succes: Jucatorul ' || p_nume_utilizator || \n                         ' a consumat ' || v_total_resurse || \n                         ' resurse pentru cladirile de tip ' || p_tip_carte || '.');\n\nEXCEPTION\n    WHEN OTHERS THEN\n        IF SQLCODE BETWEEN -20999 AND -20000 THEN\n            RAISE;\n        ELSE\n            RAISE_APPLICATION_ERROR(-20003, 'Eroare interna SQL: ' || SQLERRM);\n        END IF;\nEND analiza_consum_resurse;\n/
2e01b506-a71c-430d-8050-bd357cf0954f:1767623293723:27:F:DECLARE\n    e_user_inexistent EXCEPTION;\n    PRAGMA EXCEPTION_INIT(e_user_inexistent, -20001);\n    \n    e_tip_invalid     EXCEPTION;\n    PRAGMA EXCEPTION_INIT(e_tip_invalid, -20002);\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 1: Apel cu jucator inexistent');\n    BEGIN\n        analiza_consum_resurse('fantoma', 'Religioasa');\n    EXCEPTION\n        WHEN e_user_inexistent THEN\n            DBMS_OUTPUT.PUT_LINE(' Prins eroare -20001: ' || SQLERRM);\n    END;\n\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 2: Apel cu tip de carte gresit');\n    BEGIN\n        analiza_consum_resurse('lupul_alb', 'Magica');\n    EXCEPTION\n        WHEN e_tip_invalid THEN\n            DBMS_OUTPUT.PUT_LINE(' Prins eroare -20002: ' || SQLERRM);\n    END;\n\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 3: Apel corect');\n    BEGIN\n        analiza_consum_resurse('lupul_alb', 'Religioasa');\n    EXCEPTION\n        WHEN OTHERS THEN\n            DBMS_OUTPUT.PUT_LINE(' -> Eroare neasteptata: ' || SQLERRM);\n    END;\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\nEND;\n/
d28ca260-99dd-402c-af3f-6ea3e0a07062:1767625806003:37:F:CREATE OR REPLACE PROCEDURE detalii_consum_resurse (\n    p_nume_utilizator IN JUCATOR.nume_utilizator%TYPE,\n    p_tip_carte       IN CARTE.tip_carte%TYPE\n) \nIS\n    v_count_user    NUMBER;\n    v_found_data    BOOLEAN := FALSE;\nBEGIN\n    SELECT COUNT(*) INTO v_count_user \n    FROM JUCATOR \n    WHERE nume_utilizator = p_nume_utilizator;\n    \n    IF v_count_user = 0 THEN\n        RAISE_APPLICATION_ERROR(-20001, 'Jucatorul "' || p_nume_utilizator || '" nu exista in baza de date.');\n    END IF;\n\n    IF p_tip_carte NOT IN ('Negustoreasca', 'Boiereasca', 'Religioasa', 'Militara', 'Unica') THEN\n        RAISE_APPLICATION_ERROR(-20002, 'Tipul "' || p_tip_carte || '" nu este valid. Alegeti un tip corect.');\n    END IF;\n\n    FOR rec IN (\n        SELECT c.nume AS nume_cladire, \n               tr.nume AS nume_resursa, \n               f.cantitate_folosita\n        FROM JUCATOR j\n        JOIN ORAS o ON j.id_jucator = o.id_jucator\n        JOIN CLADIRE cl ON o.id_oras = cl.id_oras\n        JOIN CARTE c ON cl.id_carte = c.id_carte\n        JOIN FOLOSESTE f ON cl.id_cladire = f.id_cladire\n        JOIN RESURSA r ON f.id_resursa = r.id_resursa\n        JOIN TIP_RESURSA tr ON r.id_tip_res = tr.id_tip_res\n        WHERE j.nume_utilizator = p_nume_utilizator\n          AND c.tip_carte = p_tip_carte\n    ) LOOP\n        v_found_data := TRUE;\n        DBMS_OUTPUT.PUT_LINE('Jucatorul ' || p_nume_utilizator || \n                             ' a consumat ' || rec.cantitate_folosita || \n                             ' ' || rec.nume_resursa || \n                             ' pentru a construi ' || rec.nume_cladire || '.');\n    END LOOP;\n\n    IF NOT v_found_data THEN\n        DBMS_OUTPUT.PUT_LINE('Info: Jucatorul ' || p_nume_utilizator || \n                             ' nu are constructii de tipul ' || p_tip_carte || \n                             ' sau nu au fost inregistrate costuri.');\n    END IF;\n\nEXCEPTION\n    WHEN OTHERS THEN\n        IF SQLCODE BETWEEN -20999 AND -20000 THEN\n            RAISE;\n        ELSE\n            RAISE_APPLICATION_ERROR(-20003, 'Eroare interna SQL: ' || SQLERRM);\n        END IF;\nEND detalii_consum_resurse;\n/
77fc4f0f-e27b-4b74-8af0-f475fb8dc324:1767625807483:17:F:DECLARE\n    e_user_inexistent EXCEPTION;\n    PRAGMA EXCEPTION_INIT(e_user_inexistent, -20001);\n    \n    e_tip_invalid     EXCEPTION;\n    PRAGMA EXCEPTION_INIT(e_tip_invalid, -20002);\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 1: Apel cu jucator inexistent');\n    BEGIN\n        detalii_consum_resurse('fantoma', 'Religioasa');\n    EXCEPTION\n        WHEN e_user_inexistent THEN\n            DBMS_OUTPUT.PUT_LINE(' Prins eroare -20001: ' || SQLERRM);\n    END;\n\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 2: Apel cu tip de carte gresit');\n    BEGIN\n        detalii_consum_resurse('lupul_alb', 'Magica');\n    EXCEPTION\n        WHEN e_tip_invalid THEN\n            DBMS_OUTPUT.PUT_LINE(' Prins eroare -20002: ' || SQLERRM);\n    END;\n\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\n    DBMS_OUTPUT.PUT_LINE('Caz 3: Apel corect (Detalii Resurse)');\n    BEGIN\n        detalii_consum_resurse('lupul_alb', 'Religioasa');\n    EXCEPTION\n        WHEN OTHERS THEN\n            DBMS_OUTPUT.PUT_LINE(' -> Eroare neasteptata: ' || SQLERRM);\n    END;\n    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');\nEND;\n/
