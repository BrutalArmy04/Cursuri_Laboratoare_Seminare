a62ba678-2570-4abd-b3d4-8aba356cf692:1767617023134:117:F:BEGIN\n    -- Asigura-te ca exista un joc cu ID 1 si jucatorul 'lupul_alb' in datele tale\n    raport_avere_jucator('lupul_alb', 1); \nEND;\n/
