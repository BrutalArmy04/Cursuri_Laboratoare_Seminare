5dc4eda8-dcf8-4fd3-9343-23410e1a8df3:1765125883846:499:F:CREATE OR REPLACE PROCEDURE proc_ex1  \n(v_value dummy_table.value%TYPE, v_procent NUMBER)  \nAS \n    PRAGMA AUTONOMOUS_TRANSACTION; -- Face ca procedura să aibă propria tranzacție\n    v_row_count NUMBER;\n    v_message VARCHAR2(400);\nBEGIN \n    -- Logăm începutul procedurii (în tranzacție separată)\n    v_message := 'Procedura a inceput pentru v_value=' || v_value || ', procent=' || v_procent;\n    INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n    COMMIT; -- COMMIT necesar în tranzacții autonome\n    \n    -- Operația principală\n    UPDATE  dummy_table\n    SET     value = value * (1 + v_procent/100)\n    WHERE   value = v_value;\n    \n    v_row_count := SQL%ROWCOUNT;\n    \n    -- Logăm rezultatul (tot în tranzacție separată)\n    IF v_row_count > 0 THEN\n        v_message := 'Update realizat cu succes pentru ' || v_row_count || ' randuri';\n    ELSE\n        v_message := 'Nu exista randuri cu valoarea ' || v_value;\n        RAISE_APPLICATION_ERROR(-20000, v_message);\n    END IF;\n    \n    INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n    COMMIT; -- Commit pentru log\n    \nEXCEPTION \n    WHEN OTHERS THEN\n        -- Logăm eroarea (tot în tranzacție separată)\n        INSERT INTO proc_log(procedure_name, message) \n        VALUES ('PROC_EX1', 'Eroare: ' || SQLERRM);\n        COMMIT;\n        RAISE; -- Re-aruncăm eroarea către apelator\nEND;\n/
ad14029f-48ea-4a2a-a660-9c9b6c5fb9f0:1765125955698:284:F:CREATE OR REPLACE PROCEDURE proc_ex1  \n(v_value dummy_table.value%TYPE, v_procent NUMBER)  \nAS \n    PRAGMA AUTONOMOUS_TRANSACTION;\n    v_row_count NUMBER;\n    v_message VARCHAR2(400);\n    v_error_msg VARCHAR2(400); -- Variabilă nouă pentru mesajul de eroare\nBEGIN \n    -- Logăm începutul procedurii\n    v_message := 'Procedura a inceput pentru v_value=' || v_value || ', procent=' || v_procent;\n    INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n    COMMIT;\n    \n    -- Operația principală\n    UPDATE dummy_table\n    SET value = value * (1 + v_procent/100)\n    WHERE value = v_value;\n    \n    v_row_count := SQL%ROWCOUNT;\n    \n    -- Logăm rezultatul\n    IF v_row_count > 0 THEN\n        v_message := 'Update realizat cu succes pentru ' || v_row_count || ' randuri';\n    ELSE\n        v_message := 'Nu exista randuri cu valoarea ' || v_value;\n        -- Logăm înainte de a arunca eroarea\n        INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n        COMMIT;\n        RAISE_APPLICATION_ERROR(-20000, v_message);\n    END IF;\n    \n    INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n    COMMIT;\n    \nEXCEPTION \n    WHEN OTHERS THEN\n        -- Salvează mesajul de eroare într-o variabilă\n        v_error_msg := SQLERRM;\n        \n        -- Logăm eroarea\n        INSERT INTO proc_log(procedure_name, message) \n        VALUES ('PROC_EX1', 'Eroare: ' || v_error_msg);\n        COMMIT;\n        \n        -- Re-aruncăm eroarea către apelator\n        RAISE_APPLICATION_ERROR(-20001, v_error_msg);\nEND;\n/
445021fe-6cfe-4c25-8ea9-1b37e06c1d26:1765125979432:0:S:set serveroutput on;
4f89ec89-8510-4e25-a587-40e366452107:1765126137669:30:F:CREATE OR REPLACE PROCEDURE proc_ex1  \n(v_value dummy_table.value%TYPE, v_procent NUMBER)  \nAS \n    PRAGMA AUTONOMOUS_TRANSACTION;\n    v_row_count NUMBER;\n    v_message VARCHAR2(400);\n    v_error_msg VARCHAR2(400); -- var pt msg de eroare\nBEGIN \n    v_message := 'Procedura a inceput pentru v_value=' || v_value || ', procent=' || v_procent;\n    INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n    COMMIT;\n    \n    UPDATE dummy_table\n    SET value = value * (1 + v_procent/100)\n    WHERE value = v_value;\n    \n    v_row_count := SQL%ROWCOUNT;\n    \n    IF v_row_count > 0 THEN\n        v_message := 'Update realizat cu succes pentru ' || v_row_count || ' randuri';\n    ELSE\n        v_message := 'Nu exista randuri cu valoarea ' || v_value;\n        INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n        COMMIT;\n        RAISE_APPLICATION_ERROR(-20000, v_message);\n    END IF;\n    \n    INSERT INTO proc_log(procedure_name, message) VALUES ('PROC_EX1', v_message);\n    COMMIT;\n    \nEXCEPTION \n    WHEN OTHERS THEN\n        v_error_msg := SQLERRM;\n        \n        INSERT INTO proc_log(procedure_name, message) \n        VALUES ('PROC_EX1', 'Eroare: ' || v_error_msg);\n        COMMIT;\n        \n        RAISE_APPLICATION_ERROR(-20001, v_error_msg);\nEND;\n/
ae1c7483-37f2-47b2-b922-11df788ca4a0:1765126984841:104:F:CREATE OR REPLACE TYPE tab_numere IS TABLE OF NUMBER;\n/
caca6992-5902-4a54-9f7b-e7cce31ae8d8:1765126985093:21:F:CREATE OR REPLACE TYPE tab_varchar IS TABLE OF VARCHAR2(100);\n/
a669ec41-337a-46c4-a61e-c0f1c60e4a45:1765126997802:44:F:CREATE OR REPLACE PROCEDURE test_parametri_colectii (\n    -- Parametru IN cu valoare implicită\n    p_factor IN NUMBER DEFAULT 2,\n    \n    -- Parametru IN cu expresie implicită\n    p_mesaj IN VARCHAR2 := 'Mesaj implicit',\n    \n    -- Parametru OUT simplu\n    p_contor OUT NUMBER,\n    \n    -- Parametru OUT cu colecție\n    p_id_uri OUT tab_numere,\n    \n    -- Parametru IN OUT fără NOCOPY\n    p_colectie_obisnuita IN OUT tab_varchar,\n    \n    -- Parametru IN OUT cu NOCOPY\n    p_colectie_nocopy IN OUT NOCOPY tab_varchar\n) AS\n    v_start_time TIMESTAMP;\n    v_end_time TIMESTAMP;\n    v_duration_obisnuit NUMBER;\n    v_duration_nocopy NUMBER;\n    \n    -- Variabile pentru testul NOCOPY în blocul excepției\n    v_colectie_test tab_varchar;\n    \n    -- Procedură internă\n    PROCEDURE subprocedura_nocopy (\n        p_colectie IN OUT NOCOPY tab_varchar,\n        p_genereaza_exceptie IN BOOLEAN DEFAULT FALSE\n    ) IS\n    BEGIN\n        -- Modifică primul element\n        IF p_colectie.COUNT > 0 THEN\n            p_colectie(1) := p_colectie(1) || '_in_subprocedura';\n        END IF;\n        \n        -- Generează excepție dacă e cazul\n        IF p_genereaza_exceptie THEN\n            RAISE_APPLICATION_ERROR(-20001, 'Exceptie test in subprocedura');\n        END IF;\n    END;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('=== TEST PARAMETRI COLECTII ===');\n    DBMS_OUTPUT.PUT_LINE('p_factor: ' || p_factor);\n    DBMS_OUTPUT.PUT_LINE('p_mesaj: ' || p_mesaj);\n    \n    -- Inițializare parametri OUT\n    p_contor := 0;\n    p_id_uri := tab_numere();\n    \n    -- Adaugă toate ID-urile din dummy_table în colecție\n    SELECT id BULK COLLECT INTO p_id_uri\n    FROM dummy_table\n    ORDER BY id;\n    \n    p_contor := p_id_uri.COUNT;\n    DBMS_OUTPUT.PUT_LINE('Numar inregistrari gasite: ' || p_contor);\n    \n    -- Test performanță pentru colecții mari\n    -- Mai întâi populăm colecțiile cu date\n    p_colectie_obisnuita := tab_varchar();\n    p_colectie_nocopy := tab_varchar();\n    \n    -- Populează colecțiile cu 10000 de elemente\n    FOR i IN 1..10000 LOOP\n        p_colectie_obisnuita.EXTEND;\n        p_colectie_obisnuita(i) := 'Element_' || i || '_normal';\n        \n        p_colectie_nocopy.EXTEND;\n        p_colectie_nocopy(i) := 'Element_' || i || '_nocopy';\n    END LOOP;\n    \n    DBMS_OUTPUT.PUT_LINE('Colectii create cu ' || p_colectie_obisnuita.COUNT || ' elemente');\n    \n    -- Test 1: Modificare colecție normală\n    v_start_time := SYSTIMESTAMP;\n    \n    -- Procesare colecție normală (fără NOCOPY)\n    FOR i IN 1..p_colectie_obisnuita.COUNT LOOP\n        p_colectie_obisnuita(i) := p_colectie_obisnuita(i) || '_modificat';\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    v_duration_obisnuit := EXTRACT(SECOND FROM (v_end_time - v_start_time));\n    \n    -- Test 2: Modificare colecție cu NOCOPY\n    v_start_time := SYSTIMESTAMP;\n    \n    -- Procesare colecție cu NOCOPY\n    FOR i IN 1..p_colectie_nocopy.COUNT LOOP\n        p_colectie_nocopy(i) := p_colectie_nocopy(i) || '_modificat';\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    v_duration_nocopy := EXTRACT(SECOND FROM (v_end_time - v_start_time));\n    \n    -- Afișează rezultatele performanței\n    DBMS_OUTPUT.PUT_LINE('--- Performanta procesare colectii ---');\n    DBMS_OUTPUT.PUT_LINE('Durata procesare normala: ' || v_duration_obisnuit || ' secunde');\n    DBMS_OUTPUT.PUT_LINE('Durata procesare NOCOPY: ' || v_duration_nocopy || ' secunde');\n    \n    -- Demonstrație excepție și rollback cu NOCOPY\n    DBMS_OUTPUT.PUT_LINE('--- Test exceptie cu NOCOPY ---');\n    \n    -- Inițializează colecția de test\n    v_colectie_test := tab_varchar('Element1', 'Element2', 'Element3');\n    \n    DBMS_OUTPUT.PUT_LINE('Inainte de subprocedura: ' || v_colectie_test(1));\n    \n    subprocedura_nocopy(v_colectie_test, FALSE);\n    DBMS_OUTPUT.PUT_LINE('Dupa subprocedura fara exceptie: ' || v_colectie_test(1));\n    \n    -- Resetează colecția\n    v_colectie_test := tab_varchar('Element1', 'Element2', 'Element3');\n    \n    BEGIN\n        subprocedura_nocopy(v_colectie_test, TRUE);\n    EXCEPTION\n        WHEN OTHERS THEN\n            DBMS_OUTPUT.PUT_LINE('Exceptie prinsa: ' || SQLERRM);\n            -- Cu NOCOPY, modificarea a rămas chiar dacă a fost excepție!\n            DBMS_OUTPUT.PUT_LINE('Dupa exceptie (cu NOCOPY): ' || v_colectie_test(1));\n    END;\n    \n    DBMS_OUTPUT.PUT_LINE('=== Procedura terminata cu succes ===');\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare in test_parametri_colectii: ' || SQLERRM);\n        RAISE;\nEND test_parametri_colectii;\n/
63ff5dc8-923c-4dc6-932b-c64cd30fc6ab:1765127003912:20:F:CREATE OR REPLACE PROCEDURE ruleaza_test_colectii AS\n    v_contor NUMBER;\n    v_id_uri tab_numere;\n    v_colectie_normal tab_varchar;\n    v_colectie_nocopy tab_varchar;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('***** TEST 1: Toti parametri explicit *****');\n    \n    -- Inițializează colecțiile\n    v_colectie_normal := tab_varchar('A', 'B', 'C');\n    v_colectie_nocopy := tab_varchar('X', 'Y', 'Z');\n    \n    test_parametri_colectii(\n        p_factor => 3,\n        p_mesaj => 'Test explicit',\n        p_contor => v_contor,\n        p_id_uri => v_id_uri,\n        p_colectie_obisnuita => v_colectie_normal,\n        p_colectie_nocopy => v_colectie_nocopy\n    );\n    \n    DBMS_OUTPUT.PUT_LINE('Contor returnat: ' || v_contor);\n    IF v_id_uri.COUNT > 0 THEN\n        DBMS_OUTPUT.PUT_LINE('Primul ID: ' || v_id_uri(1));\n    END IF;\n    IF v_colectie_normal.COUNT > 0 THEN\n        DBMS_OUTPUT.PUT_LINE('Colecție normală după procedură: ' || v_colectie_normal(1));\n    END IF;\n    IF v_colectie_nocopy.COUNT > 0 THEN\n        DBMS_OUTPUT.PUT_LINE('Colecție NOCOPY după procedură: ' || v_colectie_nocopy(1));\n    END IF;\n    \n    DBMS_OUTPUT.PUT_LINE(CHR(10) || '***** TEST 2: Parametri impliciti *****');\n    \n    -- Resetează colecțiile\n    v_colectie_normal := tab_varchar('Test1', 'Test2');\n    v_colectie_nocopy := tab_varchar('TestA', 'TestB');\n    \n    test_parametri_colectii(\n        p_contor => v_contor,\n        p_id_uri => v_id_uri,\n        p_colectie_obisnuita => v_colectie_normal,\n        p_colectie_nocopy => v_colectie_nocopy\n        -- p_factor și p_mesaj vor lua valorile implicite\n    );\n    \n    DBMS_OUTPUT.PUT_LINE('Factor implicit: folosit valoarea default 2');\n    DBMS_OUTPUT.PUT_LINE('Mesaj implicit: "Mesaj implicit"');\n    \n    DBMS_OUTPUT.PUT_LINE(CHR(10) || '***** TEST 3: Doar parametri obligatorii *****');\n    \n    -- Test cu colecții goale\n    v_colectie_normal := tab_varchar();\n    v_colectie_nocopy := tab_varchar();\n    \n    test_parametri_colectii(\n        p_factor => 5,\n        p_contor => v_contor,\n        p_id_uri => v_id_uri,\n        p_colectie_obisnuita => v_colectie_normal,\n        p_colectie_nocopy => v_colectie_nocopy\n    );\n    \n    DBMS_OUTPUT.PUT_LINE('Test completat cu colecții goale');\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare in ruleaza_test_colectii: ' || SQLERRM);\nEND ruleaza_test_colectii;\n/
f448c7af-946e-410d-a6f2-6603d91705fc:1765127006655:19:F:CREATE OR REPLACE PROCEDURE proceseaza_dummy_table (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar\n) AS\n    v_total_modified NUMBER := 0;\n    v_nume_temp dummy_table.name%TYPE;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('Procesare dummy_table cu nume like: ' || p_nume_cautat);\n    \n    -- Colectează ID-urile care se potrivesc\n    SELECT id BULK COLLECT INTO p_id_gasite\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat;\n    \n    DBMS_OUTPUT.PUT_LINE('Gasite ' || p_id_gasite.COUNT || ' inregistrari');\n    \n    -- Inițializează colecția de nume\n    p_nume_modificate := tab_varchar();\n    p_nume_modificate.EXTEND(p_id_gasite.COUNT);\n    \n    -- Modifică valorile și colectează numele\n    FOR i IN 1..p_id_gasite.COUNT LOOP\n        UPDATE dummy_table\n        SET value = value * p_factor_modificare\n        WHERE id = p_id_gasite(i)\n        RETURNING name INTO v_nume_temp;\n        \n        p_nume_modificate(i) := v_nume_temp;\n        v_total_modified := v_total_modified + 1;\n    END LOOP;\n    \n    DBMS_OUTPUT.PUT_LINE('Modificate ' || v_total_modified || ' valori');\n    \nEXCEPTION\n    WHEN NO_DATA_FOUND THEN\n        DBMS_OUTPUT.PUT_LINE('Nu s-au gasit inregistrari');\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare: ' || SQLERRM);\n        RAISE;\nEND proceseaza_dummy_table;\n/
360e566c-35d8-4938-8525-6faf79b54e5a:1765127010235:0:F:BEGIN\n    DBMS_OUTPUT.ENABLE(1000000);\n    \n    -- Inserează date de test în dummy_table dacă nu există\n    BEGIN\n        INSERT INTO dummy_table (id, name, value) VALUES (1, 'Test1', 100);\n        INSERT INTO dummy_table (id, name, value) VALUES (2, 'Test2', 200);\n        INSERT INTO dummy_table (id, name, value) VALUES (3, 'ProdusA', 300);\n        INSERT INTO dummy_table (id, name, value) VALUES (4, 'ProdusB', 400);\n        INSERT INTO dummy_table (id, name, value) VALUES (5, 'Test3', 500);\n        COMMIT;\n    EXCEPTION\n        WHEN DUP_VAL_ON_INDEX THEN\n            NULL; -- Datele există deja\n    END;\n    \n    DBMS_OUTPUT.PUT_LINE('***** Pornire teste parametri *****');\n    \n    -- Rulează testul principal\n    ruleaza_test_colectii;\n    \n    DBMS_OUTPUT.PUT_LINE(CHR(10) || '***** TEST cu dummy_table real *****');\n    \n    DECLARE\n        v_ids tab_numere;\n        v_nume tab_varchar;\n    BEGIN\n        proceseaza_dummy_table(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.5,\n            p_id_gasite => v_ids,\n            p_nume_modificate => v_nume\n        );\n        \n        IF v_ids.COUNT > 0 THEN\n            DBMS_OUTPUT.PUT_LINE('ID-uri procesate:');\n            FOR i IN 1..v_ids.COUNT LOOP\n                DBMS_OUTPUT.PUT_LINE('  ID: ' || v_ids(i) || ', Nume: ' || v_nume(i));\n            END LOOP;\n        END IF;\n    END;\n    \n    DBMS_OUTPUT.PUT_LINE(CHR(10) || '***** Teste completate cu succes! *****');\n    \n    -- Afișează starea finală a dummy_table\n    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Starea finala dummy_table:');\n    FOR rec IN (SELECT id, name, value FROM dummy_table ORDER BY id) LOOP\n        DBMS_OUTPUT.PUT_LINE('ID: ' || rec.id || ', Nume: ' || rec.name || ', Valoare: ' || rec.value);\n    END LOOP;\n    \nEND;\n/
2c0ea178-1d6c-43fa-9682-32455818bdb8:1765127411030:22:F:CREATE OR REPLACE PROCEDURE proceseaza_dummy_table (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar\n) AS\n    v_total_modified NUMBER := 0;\n    v_nume_temp dummy_table.name%TYPE;\n    CURSOR c_date IS\n        SELECT id, name\n        FROM dummy_table\n        WHERE name LIKE p_nume_cautat\n        FOR UPDATE; -- Blochează rândurile pentru update\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('Procesare dummy_table cu nume like: ' || p_nume_cautat);\n    \n    -- Inițializează colecțiile\n    p_id_gasite := tab_numere();\n    p_nume_modificate := tab_varchar();\n    \n    -- Folosește cursor pentru a evita problema RETURNING INTO\n    FOR rec IN c_date LOOP\n        -- Modifică valoarea\n        UPDATE dummy_table\n        SET value = value * p_factor_modificare\n        WHERE CURRENT OF c_date;\n        \n        -- Adaugă la colecții\n        p_id_gasite.EXTEND;\n        p_id_gasite(p_id_gasite.COUNT) := rec.id;\n        \n        p_nume_modificate.EXTEND;\n        p_nume_modificate(p_nume_modificate.COUNT) := rec.name;\n        \n        v_total_modified := v_total_modified + 1;\n    END LOOP;\n    \n    DBMS_OUTPUT.PUT_LINE('Gasite ' || p_id_gasite.COUNT || ' inregistrari');\n    DBMS_OUTPUT.PUT_LINE('Modificate ' || v_total_modified || ' valori');\n    \nEXCEPTION\n    WHEN NO_DATA_FOUND THEN\n        DBMS_OUTPUT.PUT_LINE('Nu s-au gasit inregistrari');\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare: ' || SQLERRM);\n        RAISE;\nEND proceseaza_dummy_table;\n/
5849c63a-79cb-460d-8c10-b6585d4fc1ff:1765127419476:18:F:CREATE OR REPLACE PROCEDURE proceseaza_dummy_table_v2 (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar\n) AS\n    v_total_modified NUMBER := 0;\n    v_error_count NUMBER := 0;\n    v_errors EXCEPTION;\n    PRAGMA EXCEPTION_INIT(v_errors, -24381);\n    \n    TYPE tab_id IS TABLE OF dummy_table.id%TYPE;\n    TYPE tab_name IS TABLE OF dummy_table.name%TYPE;\n    TYPE tab_value IS TABLE OF dummy_table.value%TYPE;\n    \n    v_ids tab_id;\n    v_names tab_name;\n    v_values tab_value;\n    v_values_new tab_value;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('Procesare dummy_table_v2 cu nume like: ' || p_nume_cautat);\n    \n    -- Colectează toate datele într-o singură operațiune\n    SELECT id, name, value\n    BULK COLLECT INTO v_ids, v_names, v_values\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat;\n    \n    DBMS_OUTPUT.PUT_LINE('Gasite ' || v_ids.COUNT || ' inregistrari');\n    \n    -- Calculează noile valori\n    v_values_new := tab_value();\n    v_values_new.EXTEND(v_ids.COUNT);\n    \n    FOR i IN 1..v_ids.COUNT LOOP\n        v_values_new(i) := v_values(i) * p_factor_modificare;\n    END LOOP;\n    \n    -- Actualizează toate rândurile într-o singură operațiune cu FORALL\n    FORALL i IN 1..v_ids.COUNT\n        UPDATE dummy_table\n        SET value = v_values_new(i)\n        WHERE id = v_ids(i);\n    \n    v_total_modified := v_ids.COUNT;\n    \n    -- Setează parametrii OUT\n    p_id_gasite := tab_numere();\n    p_nume_modificate := tab_varchar();\n    \n    p_id_gasite.EXTEND(v_ids.COUNT);\n    p_nume_modificate.EXTEND(v_ids.COUNT);\n    \n    FOR i IN 1..v_ids.COUNT LOOP\n        p_id_gasite(i) := v_ids(i);\n        p_nume_modificate(i) := v_names(i);\n    END LOOP;\n    \n    DBMS_OUTPUT.PUT_LINE('Modificate ' || v_total_modified || ' valori');\n    \nEXCEPTION\n    WHEN NO_DATA_FOUND THEN\n        DBMS_OUTPUT.PUT_LINE('Nu s-au gasit inregistrari');\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare: ' || SQLERRM);\n        RAISE;\nEND proceseaza_dummy_table_v2;\n/
b5291f59-59a3-4e08-9111-ab7015a2c13e:1765127423342:17:F:CREATE OR REPLACE PROCEDURE proceseaza_dummy_table_simplu (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar\n) AS\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('Procesare dummy_table_simplu cu nume like: ' || p_nume_cautat);\n    \n    -- Colectează ID-urile care se potrivesc\n    SELECT id BULK COLLECT INTO p_id_gasite\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat;\n    \n    DBMS_OUTPUT.PUT_LINE('Gasite ' || p_id_gasite.COUNT || ' inregistrari');\n    \n    -- Colectează numele într-o colecție separată\n    SELECT name BULK COLLECT INTO p_nume_modificate\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat\n    ORDER BY id; -- Important: aceeași ordine ca p_id_gasite\n    \n    -- Actualizează valorile\n    FOR i IN 1..p_id_gasite.COUNT LOOP\n        UPDATE dummy_table\n        SET value = value * p_factor_modificare\n        WHERE id = p_id_gasite(i);\n    END LOOP;\n    \n    DBMS_OUTPUT.PUT_LINE('Modificate ' || p_id_gasite.COUNT || ' valori');\n    \nEXCEPTION\n    WHEN NO_DATA_FOUND THEN\n        DBMS_OUTPUT.PUT_LINE('Nu s-au gasit inregistrari');\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare: ' || SQLERRM);\n        RAISE;\nEND proceseaza_dummy_table_simplu;\n/
6569e31d-e796-4bde-9dd5-879c98a2f9d5:1765127432255:268:F:BEGIN\n    DBMS_OUTPUT.ENABLE(1000000);\n    \n    -- Asigură-te că dummy_table are date unice pe ID\n    DELETE FROM dummy_table WHERE id IN (1,2,3,4,5);\n    \n    INSERT INTO dummy_table (id, name, value) VALUES (1, 'Test1', 100);\n    INSERT INTO dummy_table (id, name, value) VALUES (2, 'Test2', 200);\n    INSERT INTO dummy_table (id, name, value) VALUES (3, 'ProdusA', 300);\n    INSERT INTO dummy_table (id, name, value) VALUES (4, 'ProdusB', 400);\n    INSERT INTO dummy_table (id, name, value) VALUES (5, 'Test3', 500);\n    COMMIT;\n    \n    DBMS_OUTPUT.PUT_LINE('***** TEST cu dummy_table simplu *****');\n    \n    DECLARE\n        v_ids tab_numere;\n        v_nume tab_varchar;\n    BEGIN\n        proceseaza_dummy_table_simplu(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.5,\n            p_id_gasite => v_ids,\n            p_nume_modificate => v_nume\n        );\n        \n        IF v_ids.COUNT > 0 THEN\n            DBMS_OUTPUT.PUT_LINE('ID-uri procesate:');\n            FOR i IN 1..v_ids.COUNT LOOP\n                DBMS_OUTPUT.PUT_LINE('  ID: ' || v_ids(i) || ', Nume: ' || v_nume(i));\n            END LOOP;\n        END IF;\n    END;\n    \n    DBMS_OUTPUT.PUT_LINE(CHR(10) || '***** TEST cu dummy_table v2 (FORALL) *****');\n    \n    DECLARE\n        v_ids tab_numere;\n        v_nume tab_varchar;\n    BEGIN\n        proceseaza_dummy_table_v2(\n            p_nume_cautat => 'Prod%',\n            p_factor_modificare => 2.0,\n            p_id_gasite => v_ids,\n            p_nume_modificate => v_nume\n        );\n        \n        IF v_ids.COUNT > 0 THEN\n            DBMS_OUTPUT.PUT_LINE('ID-uri procesate:');\n            FOR i IN 1..v_ids.COUNT LOOP\n                DBMS_OUTPUT.PUT_LINE('  ID: ' || v_ids(i) || ', Nume: ' || v_nume(i));\n            END LOOP;\n        END IF;\n    END;\n    \n    DBMS_OUTPUT.PUT_LINE(CHR(10) || '***** Teste completate cu succes! *****');\n    \n    -- Afișează starea finală a dummy_table\n    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Starea finala dummy_table:');\n    FOR rec IN (SELECT id, name, value FROM dummy_table ORDER BY id) LOOP\n        DBMS_OUTPUT.PUT_LINE('ID: ' || rec.id || ', Nume: ' || rec.name || ', Valoare: ' || rec.value);\n    END LOOP;\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare in blocul principal: ' || SQLERRM);\n        ROLLBACK;\n        RAISE;\nEND;\n/
9f0540e6-bfd5-44de-b536-0d7e31aa4680:1765127715856:152:F:CREATE OR REPLACE TYPE tab_numere IS TABLE OF NUMBER;\n/
58850764-668b-4cfd-8a6f-0377e8b83978:1765127716147:12:F:CREATE OR REPLACE TYPE tab_varchar IS TABLE OF VARCHAR2(100);\n/
2f1edff9-8f63-40f8-9319-7005b00c4eaa:1765127719229:12:F:CREATE OR REPLACE PROCEDURE solutia_cursor (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar,\n    p_timp_executie OUT NUMBER\n) AS\n    v_start_time TIMESTAMP;\n    v_end_time TIMESTAMP;\n    CURSOR c_date IS\n        SELECT id, name\n        FROM dummy_table\n        WHERE name LIKE p_nume_cautat\n        FOR UPDATE;\nBEGIN\n    v_start_time := SYSTIMESTAMP;\n    \n    -- Inițializează colecțiile\n    p_id_gasite := tab_numere();\n    p_nume_modificate := tab_varchar();\n    \n    -- Folosește cursor pentru update\n    FOR rec IN c_date LOOP\n        UPDATE dummy_table\n        SET value = value * p_factor_modificare\n        WHERE CURRENT OF c_date;\n        \n        p_id_gasite.EXTEND;\n        p_id_gasite(p_id_gasite.COUNT) := rec.id;\n        \n        p_nume_modificate.EXTEND;\n        p_nume_modificate(p_nume_modificate.COUNT) := rec.name;\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    p_timp_executie := EXTRACT(SECOND FROM (v_end_time - v_start_time)) * 1000; -- milisecunde\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        p_timp_executie := -1; -- Indică eroare\n        RAISE;\nEND solutia_cursor;\n/
03d46dfb-b721-45e0-b3ed-8f2b20622023:1765127722957:15:F:CREATE OR REPLACE PROCEDURE solutia_forall (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar,\n    p_timp_executie OUT NUMBER\n) AS\n    v_start_time TIMESTAMP;\n    v_end_time TIMESTAMP;\n    \n    TYPE tab_id IS TABLE OF dummy_table.id%TYPE;\n    TYPE tab_name IS TABLE OF dummy_table.name%TYPE;\n    TYPE tab_value IS TABLE OF dummy_table.value%TYPE;\n    \n    v_ids tab_id;\n    v_names tab_name;\n    v_values tab_value;\n    v_values_new tab_value;\nBEGIN\n    v_start_time := SYSTIMESTAMP;\n    \n    -- Colectează toate datele\n    SELECT id, name, value\n    BULK COLLECT INTO v_ids, v_names, v_values\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat;\n    \n    -- Calculează noile valori\n    v_values_new := tab_value();\n    v_values_new.EXTEND(v_ids.COUNT);\n    \n    FOR i IN 1..v_ids.COUNT LOOP\n        v_values_new(i) := v_values(i) * p_factor_modificare;\n    END LOOP;\n    \n    -- Actualizează cu FORALL\n    FORALL i IN 1..v_ids.COUNT\n        UPDATE dummy_table\n        SET value = v_values_new(i)\n        WHERE id = v_ids(i);\n    \n    -- Setează parametrii OUT\n    p_id_gasite := tab_numere();\n    p_nume_modificate := tab_varchar();\n    \n    p_id_gasite.EXTEND(v_ids.COUNT);\n    p_nume_modificate.EXTEND(v_ids.COUNT);\n    \n    FOR i IN 1..v_ids.COUNT LOOP\n        p_id_gasite(i) := v_ids(i);\n        p_nume_modificate(i) := v_names(i);\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    p_timp_executie := EXTRACT(SECOND FROM (v_end_time - v_start_time)) * 1000; -- milisecunde\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        p_timp_executie := -1; -- Indică eroare\n        RAISE;\nEND solutia_forall;\n/
b9786cfa-6a88-4d59-8052-ab12bad328bd:1765127725256:19:F:CREATE OR REPLACE PROCEDURE solutia_simpla (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar,\n    p_timp_executie OUT NUMBER\n) AS\n    v_start_time TIMESTAMP;\n    v_end_time TIMESTAMP;\nBEGIN\n    v_start_time := SYSTIMESTAMP;\n    \n    -- Colectează ID-urile și numele\n    SELECT id BULK COLLECT INTO p_id_gasite\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat;\n    \n    SELECT name BULK COLLECT INTO p_nume_modificate\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat\n    ORDER BY id;\n    \n    -- Actualizează în buclă\n    FOR i IN 1..p_id_gasite.COUNT LOOP\n        UPDATE dummy_table\n        SET value = value * p_factor_modificare\n        WHERE id = p_id_gasite(i);\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    p_timp_executie := EXTRACT(SECOND FROM (v_end_time - v_start_time)) * 1000; -- milisecunde\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        p_timp_executie := -1; -- Indică eroare\n        RAISE;\nEND solutia_simpla;\n/
d3ec74cf-1bfb-4b2d-90cd-476b98e7ba76:1765127750348:38:F:CREATE OR REPLACE PROCEDURE test_performanta_solutii (\n    p_num_iteratii IN NUMBER DEFAULT 5\n) AS\n    v_timp_cursor_total NUMBER := 0;\n    v_timp_forall_total NUMBER := 0;\n    v_timp_simpla_total NUMBER := 0;\n    \n    v_timp_cursor NUMBER;\n    v_timp_forall NUMBER;\n    v_timp_simpla NUMBER;\n    \n    v_ids_cursor tab_numere;\n    v_ids_forall tab_numere;\n    v_ids_simpla tab_numere;\n    \n    v_nume_cursor tab_varchar;\n    v_nume_forall tab_varchar;\n    v_nume_simpla tab_varchar;\n    \n    v_iteratie NUMBER;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('============================================');\n    DBMS_OUTPUT.PUT_LINE('TEST PERFORMANTA SOLUTII PROCESSARE DUMMY_TABLE');\n    DBMS_OUTPUT.PUT_LINE('============================================');\n    DBMS_OUTPUT.PUT_LINE('Număr iterații: ' || p_num_iteratii);\n    DBMS_OUTPUT.PUT_LINE('');\n    \n    -- Pregătește datele pentru test (creează mai multe rânduri)\n    DBMS_OUTPUT.PUT_LINE('Pregătire date test...');\n    DELETE FROM dummy_table;\n    \n    -- Inserează date de test (1000 de rânduri)\n    FOR i IN 1..1000 LOOP\n        INSERT INTO dummy_table (id, name, value) \n        VALUES (i, \n                CASE \n                    WHEN MOD(i, 3) = 0 THEN 'Test' || i\n                    WHEN MOD(i, 3) = 1 THEN 'Produs' || i\n                    ELSE 'Item' || i\n                END,\n                i * 10);\n    END LOOP;\n    COMMIT;\n    \n    DBMS_OUTPUT.PUT_LINE('Inserate 1000 de rânduri în dummy_table');\n    DBMS_OUTPUT.PUT_LINE('');\n    \n    -- Rulează teste pentru fiecare iterație\n    FOR v_iteratie IN 1..p_num_iteratii LOOP\n        DBMS_OUTPUT.PUT_LINE('--- Iteratia ' || v_iteratie || ' ---');\n        \n        -- Test 1: Cursor FOR UPDATE\n        solutia_cursor(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.1,\n            p_id_gasite => v_ids_cursor,\n            p_nume_modificate => v_nume_cursor,\n            p_timp_executie => v_timp_cursor\n        );\n        v_timp_cursor_total := v_timp_cursor_total + v_timp_cursor;\n        DBMS_OUTPUT.PUT_LINE('Solutia CURSOR: ' || ROUND(v_timp_cursor, 2) || ' ms');\n        \n        -- Resetează valorile pentru următoarea soluție\n        UPDATE dummy_table SET value = value / 1.1 WHERE name LIKE 'Test%';\n        \n        -- Test 2: FORALL\n        solutia_forall(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.1,\n            p_id_gasite => v_ids_forall,\n            p_nume_modificate => v_nume_forall,\n            p_timp_executie => v_timp_forall\n        );\n        v_timp_forall_total := v_timp_forall_total + v_timp_forall;\n        DBMS_OUTPUT.PUT_LINE('Solutia FORALL:  ' || ROUND(v_timp_forall, 2) || ' ms');\n        \n        -- Resetează valorile pentru următoarea soluție\n        UPDATE dummy_table SET value = value / 1.1 WHERE name LIKE 'Test%';\n        \n        -- Test 3: Simplă cu buclă FOR\n        solutia_simpla(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.1,\n            p_id_gasite => v_ids_simpla,\n            p_nume_modificate => v_nume_simpla,\n            p_timp_executie => v_timp_simpla\n        );\n        v_timp_simpla_total := v_timp_simpla_total + v_timp_simpla;\n        DBMS_OUTPUT.PUT_LINE('Solutia SIMPLA:  ' || ROUND(v_timp_simpla, 2) || ' ms');\n        \n        DBMS_OUTPUT.PUT_LINE('');\n    END LOOP;\n    \n    -- Calculează și afișează media\n    DBMS_OUTPUT.PUT_LINE('============================================');\n    DBMS_OUTPUT.PUT_LINE('REZULTATE FINALE (medie pe ' || p_num_iteratii || ' iteratii)');\n    DBMS_OUTPUT.PUT_LINE('============================================');\n    \n    DBMS_OUTPUT.PUT_LINE('Solutia CURSOR: ' || ROUND(v_timp_cursor_total / p_num_iteratii, 2) || ' ms (medie)');\n    DBMS_OUTPUT.PUT_LINE('Solutia FORALL:  ' || ROUND(v_timp_forall_total / p_num_iteratii, 2) || ' ms (medie)');\n    DBMS_OUTPUT.PUT_LINE('Solutia SIMPLA:  ' || ROUND(v_timp_simpla_total / p_num_iteratii, 2) || ' ms (medie)');\n    DBMS_OUTPUT.PUT_LINE('');\n    \n    -- Analiză comparativă\n    DBMS_OUTPUT.PUT_LINE('ANALIZA COMPARATIVA:');\n    DBMS_OUTPUT.PUT_LINE('-------------------');\n    \n    DECLARE\n        v_min_timp NUMBER;\n        v_winner VARCHAR2(50);\n    BEGIN\n        -- Determină cel mai rapid timp\n        v_min_timp := LEAST(\n            v_timp_cursor_total / p_num_iteratii,\n            v_timp_forall_total / p_num_iteratii,\n            v_timp_simpla_total / p_num_iteratii\n        );\n        \n        IF v_min_timp = v_timp_cursor_total / p_num_iteratii THEN\n            v_winner := 'CURSOR';\n        ELSIF v_min_timp = v_timp_forall_total / p_num_iteratii THEN\n            v_winner := 'FORALL';\n        ELSE\n            v_winner := 'SIMPLA';\n        END IF;\n        \n        DBMS_OUTPUT.PUT_LINE('Cea mai rapida solutie: ' || v_winner);\n        DBMS_OUTPUT.PUT_LINE('');\n        \n        -- Raport procentual\n        DBMS_OUTPUT.PUT_LINE('Raport performanta (fata de FORALL ca benchmark):');\n        DBMS_OUTPUT.PUT_LINE('CURSOR: ' || \n            ROUND((v_timp_cursor_total / p_num_iteratii) / (v_timp_forall_total / p_num_iteratii) * 100, 1) || '%');\n        DBMS_OUTPUT.PUT_LINE('FORALL:  100% (benchmark)');\n        DBMS_OUTPUT.PUT_LINE('SIMPLA: ' || \n            ROUND((v_timp_simpla_total / p_num_iteratii) / (v_timp_forall_total / p_num_iteratii) * 100, 1) || '%');\n    END;\n    \n    DBMS_OUTPUT.PUT_LINE('');\n    DBMS_OUTPUT.PUT_LINE('============================================');\n    DBMS_OUTPUT.PUT_LINE('TEST COMPLETAT CU SUCCES');\n    DBMS_OUTPUT.PUT_LINE('============================================');\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare in test_performanta_solutii: ' || SQLERRM);\n        ROLLBACK;\n        RAISE;\nEND test_performanta_solutii;\n/
a03d353f-06ad-436c-ba24-01330252eb08:1765127751317:939:F:BEGIN\n    DBMS_OUTPUT.ENABLE(1000000);\n    \n    -- Rulează testul de performanță\n    test_performanta_solutii(p_num_iteratii => 3); -- Poți modifica numărul de iterații\n    \n    -- Curăță tabela după test\n    DELETE FROM dummy_table;\n    COMMIT;\n    \n    DBMS_OUTPUT.PUT_LINE('Tabela dummy_table a fost curățată.');\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare: ' || SQLERRM);\n        ROLLBACK;\nEND;\n/
b811ff11-8384-4a97-b41a-8389c3035813:1765128279664:13:F:CREATE OR REPLACE TYPE tab_numere IS TABLE OF NUMBER;\n/
80392862-d2b4-4b0c-93f4-5d6283c4b99a:1765128279868:9:F:CREATE OR REPLACE TYPE tab_varchar IS TABLE OF VARCHAR2(100);\n/
06d95f09-1873-4587-a2c9-9e4cd5802533:1765128285585:50:F:CREATE OR REPLACE PROCEDURE solutia_cursor (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar,\n    p_timp_executie OUT NUMBER\n) AS\n    v_start_time TIMESTAMP;\n    v_end_time TIMESTAMP;\n    CURSOR c_date IS\n        SELECT id, name\n        FROM dummy_table\n        WHERE name LIKE p_nume_cautat\n        FOR UPDATE;\nBEGIN\n    v_start_time := SYSTIMESTAMP;\n    \n    p_id_gasite := tab_numere();\n    p_nume_modificate := tab_varchar();\n    \n    FOR rec IN c_date LOOP\n        UPDATE dummy_table\n        SET value = value * p_factor_modificare\n        WHERE CURRENT OF c_date;\n        \n        p_id_gasite.EXTEND;\n        p_id_gasite(p_id_gasite.COUNT) := rec.id;\n        \n        p_nume_modificate.EXTEND;\n        p_nume_modificate(p_nume_modificate.COUNT) := rec.name;\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    p_timp_executie := EXTRACT(SECOND FROM (v_end_time - v_start_time)) * 1000; \n    \nEXCEPTION\n    WHEN OTHERS THEN\n        p_timp_executie := -1; \n        RAISE;\nEND solutia_cursor;\n/
1d9d39de-d412-4502-9dfb-ea8bd6eb44a3:1765128295762:30:F:CREATE OR REPLACE PROCEDURE solutia_forall (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar,\n    p_timp_executie OUT NUMBER\n) AS\n    v_start_time TIMESTAMP;\n    v_end_time TIMESTAMP;\n    \n    TYPE tab_id IS TABLE OF dummy_table.id%TYPE;\n    TYPE tab_name IS TABLE OF dummy_table.name%TYPE;\n    TYPE tab_value IS TABLE OF dummy_table.value%TYPE;\n    \n    v_ids tab_id;\n    v_names tab_name;\n    v_values tab_value;\n    v_values_new tab_value;\nBEGIN\n    v_start_time := SYSTIMESTAMP;\n    \n    SELECT id, name, value\n    BULK COLLECT INTO v_ids, v_names, v_values\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat;\n    \n    v_values_new := tab_value();\n    v_values_new.EXTEND(v_ids.COUNT);\n    \n    FOR i IN 1..v_ids.COUNT LOOP\n        v_values_new(i) := v_values(i) * p_factor_modificare;\n    END LOOP;\n    \n    FORALL i IN 1..v_ids.COUNT\n        UPDATE dummy_table\n        SET value = v_values_new(i)\n        WHERE id = v_ids(i);\n\n    p_id_gasite := tab_numere();\n    p_nume_modificate := tab_varchar();\n    \n    p_id_gasite.EXTEND(v_ids.COUNT);\n    p_nume_modificate.EXTEND(v_ids.COUNT);\n    \n    FOR i IN 1..v_ids.COUNT LOOP\n        p_id_gasite(i) := v_ids(i);\n        p_nume_modificate(i) := v_names(i);\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    p_timp_executie := EXTRACT(SECOND FROM (v_end_time - v_start_time)) * 1000; \n    \nEXCEPTION\n    WHEN OTHERS THEN\n        p_timp_executie := -1;\n        RAISE;\nEND solutia_forall;\n/
52509a20-ade4-40de-8b4e-5e0cb4fa6589:1765128299906:26:F:CREATE OR REPLACE PROCEDURE solutia_simpla (\n    p_nume_cautat IN dummy_table.name%TYPE DEFAULT '%',\n    p_factor_modificare IN NUMBER DEFAULT 1,\n    p_id_gasite OUT tab_numere,\n    p_nume_modificate OUT tab_varchar,\n    p_timp_executie OUT NUMBER\n) AS\n    v_start_time TIMESTAMP;\n    v_end_time TIMESTAMP;\nBEGIN\n    v_start_time := SYSTIMESTAMP;\n\n    SELECT id BULK COLLECT INTO p_id_gasite\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat;\n    \n    SELECT name BULK COLLECT INTO p_nume_modificate\n    FROM dummy_table\n    WHERE name LIKE p_nume_cautat\n    ORDER BY id;\n    \n    FOR i IN 1..p_id_gasite.COUNT LOOP\n        UPDATE dummy_table\n        SET value = value * p_factor_modificare\n        WHERE id = p_id_gasite(i);\n    END LOOP;\n    \n    v_end_time := SYSTIMESTAMP;\n    p_timp_executie := EXTRACT(SECOND FROM (v_end_time - v_start_time)) * 1000; \n    \nEXCEPTION\n    WHEN OTHERS THEN\n        p_timp_executie := -1; \n        RAISE;\nEND solutia_simpla;\n/
1604e567-be6e-4e94-a4ac-a6f652f8f0f6:1765128316447:32:F:CREATE OR REPLACE PROCEDURE test_performanta_solutii (\n    p_num_iteratii IN NUMBER DEFAULT 5\n) AS\n    v_timp_cursor_total NUMBER := 0;\n    v_timp_forall_total NUMBER := 0;\n    v_timp_simpla_total NUMBER := 0;\n    \n    v_timp_cursor NUMBER;\n    v_timp_forall NUMBER;\n    v_timp_simpla NUMBER;\n    \n    v_ids_cursor tab_numere;\n    v_ids_forall tab_numere;\n    v_ids_simpla tab_numere;\n    \n    v_nume_cursor tab_varchar;\n    v_nume_forall tab_varchar;\n    v_nume_simpla tab_varchar;\n    \n    v_iteratie NUMBER;\nBEGIN\n    DBMS_OUTPUT.PUT_LINE('TEST PERFORMANTA SOLUTII PROCESSARE DUMMY_TABLE');\n    DBMS_OUTPUT.PUT_LINE('Numar iteratii: ' || p_num_iteratii);\n    DBMS_OUTPUT.PUT_LINE('');\n    \n\n    \n\n    FOR v_iteratie IN 1..p_num_iteratii LOOP\n        \n        -- Test 1: Cursor FOR UPDATE\n        solutia_cursor(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.1,\n            p_id_gasite => v_ids_cursor,\n            p_nume_modificate => v_nume_cursor,\n            p_timp_executie => v_timp_cursor\n        );\n        v_timp_cursor_total := v_timp_cursor_total + v_timp_cursor;\n        DBMS_OUTPUT.PUT_LINE('Solutia CURSOR: ' || ROUND(v_timp_cursor, 2) || ' ms');\n        UPDATE dummy_table SET value = value / 1.1 WHERE name LIKE 'Test%';\n        \n        -- Test 2: FORALL\n        solutia_forall(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.1,\n            p_id_gasite => v_ids_forall,\n            p_nume_modificate => v_nume_forall,\n            p_timp_executie => v_timp_forall\n        );\n        v_timp_forall_total := v_timp_forall_total + v_timp_forall;\n        DBMS_OUTPUT.PUT_LINE('Solutia FORALL:  ' || ROUND(v_timp_forall, 2) || ' ms');\n        UPDATE dummy_table SET value = value / 1.1 WHERE name LIKE 'Test%';\n        \n        -- Test 3: Simplă cu buclă FOR\n        solutia_simpla(\n            p_nume_cautat => 'Test%',\n            p_factor_modificare => 1.1,\n            p_id_gasite => v_ids_simpla,\n            p_nume_modificate => v_nume_simpla,\n            p_timp_executie => v_timp_simpla\n        );\n        v_timp_simpla_total := v_timp_simpla_total + v_timp_simpla;\n        DBMS_OUTPUT.PUT_LINE('Solutia SIMPLA:  ' || ROUND(v_timp_simpla, 2) || ' ms');\n        \n        DBMS_OUTPUT.PUT_LINE('');\n    END LOOP;\n    \n    \n    DBMS_OUTPUT.PUT_LINE('Solutia CURSOR: ' || ROUND(v_timp_cursor_total / p_num_iteratii, 2) || ' ms (medie)');\n    DBMS_OUTPUT.PUT_LINE('Solutia FORALL:  ' || ROUND(v_timp_forall_total / p_num_iteratii, 2) || ' ms (medie)');\n    DBMS_OUTPUT.PUT_LINE('Solutia SIMPLA:  ' || ROUND(v_timp_simpla_total / p_num_iteratii, 2) || ' ms (medie)');\n    DBMS_OUTPUT.PUT_LINE('');\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare in test_performanta_solutii: ' || SQLERRM);\n        ROLLBACK;\n        RAISE;\nEND test_performanta_solutii;\n/
