44a9ce58-c5ce-42ba-90d5-b397903923c3:1763816918460:0:F:SELECT\n  'INSERT INTO ANGAJATI_OBJ_TAB (' || LISTAGG(column_name, ', ') WITHIN GROUP (ORDER BY column_id) || ') VALUES (' ||\n  LISTAGG(\n    CASE \n      WHEN data_type LIKE '%CHAR%' THEN '''''' || REPLACE(REPLACE(REPLACE(column_value, '''', ''''''), CHR(10), ' '), CHR(13), ' ') || ''''''\n      WHEN data_type = 'DATE' THEN 'TO_DATE(''' || TO_CHAR(column_value, 'YYYY-MM-DD HH24:MI:SS') || ''', ''YYYY-MM-DD HH24:MI:SS'')'\n      WHEN data_type LIKE 'NUMBER%' THEN TO_CHAR(column_value)\n      ELSE 'NULL' -- For unsupported types (LOBs etc)\n    END,\n    ', '\n  ) WITHIN GROUP (ORDER BY column_id) || ');' AS insert_statement\nFROM\n  ANGAJATI_OBJ_TAB,\n  user_tab_columns utc\nWHERE\n  utc.table_name = 'ANGAJATI_OBJ_TAB'\n  AND utc.column_name = column_name\nGROUP BY ROWID;
