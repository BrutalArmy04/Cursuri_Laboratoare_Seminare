7463656f-d11d-44b2-8f30-c2c1dcd52864:1763817028297:13:S:DECLARE\n  v_table_name VARCHAR2(30) := 'ANGAJATI_OBJ_TAB';\n  v_sql        CLOB;\n  v_rec_insert VARCHAR2(32767);\n\n  TYPE col_rec IS RECORD (\n    column_name VARCHAR2(128),\n    data_type   VARCHAR2(30)\n  );\n\n  TYPE col_tab IS TABLE OF col_rec;\n\n  cols col_tab;\n\nBEGIN\n  -- Get columns\n  SELECT column_name, data_type\n    BULK COLLECT INTO cols\n    FROM user_tab_columns\n   WHERE table_name = v_table_name\n   ORDER BY column_id;\n\n  -- Build SQL to select rows and build insert statements\n  v_sql := 'SELECT ''INSERT INTO ' || v_table_name || ' ('\n           || LISTAGG(column_name, ', ') WITHIN GROUP (ORDER BY column_id)\n           || ') VALUES ('' || ';\n\n  FOR i IN 1 .. cols.COUNT LOOP\n    IF cols(i).data_type LIKE '%CHAR%' THEN\n      v_sql := v_sql || ''''''''' || REPLACE(REPLACE(REPLACE(' || cols(i).column_name || ', ''''''', ''''''''''), CHR(10), '' ''), CHR(13), '' '') || '''''''''';\n    ELSIF cols(i).data_type = 'DATE' THEN\n      v_sql := v_sql || '''TO_DATE(''''' || TO_CHAR(' || cols(i).column_name || ', ''YYYY-MM-DD HH24:MI:SS'') || ''''', ''''YYYY-MM-DD HH24:MI:SS'''')''';\n    ELSIF cols(i).data_type LIKE 'NUMBER%' THEN\n      v_sql := v_sql || 'NVL(TO_CHAR(' || cols(i).column_name || '), ''NULL'')';\n    ELSE\n      v_sql := v_sql || '''NULL''';\n    END IF;\n\n    IF i < cols.COUNT THEN\n      v_sql := v_sql || ' || '','' || ';\n    END IF;\n  END LOOP;\n\n  v_sql := v_sql || ' || '')'' FROM ' || v_table_name;\n\n  -- Output the SQL for debugging\n  DBMS_OUTPUT.PUT_LINE('Generated SQL:');\n  DBMS_OUTPUT.PUT_LINE(v_sql);\n\n  -- Execute and output inserts\n  FOR rec IN (EXECUTE IMMEDIATE v_sql) LOOP\n    DBMS_OUTPUT.PUT_LINE(rec.COLUMN_VALUE);\n  END LOOP;\n\nEND;\n/
