01ebc8e1-9c6d-4697-927b-c17245c099d9:1765206923730:50:F:CREATE OR REPLACE FUNCTION get_department_top_employees\nRETURN dept_info_list PIPELINED\nIS\n    CURSOR dept_cursor IS\n        SELECT d.department_id,\n               d.department_name,\n               e.first_name || ' ' || e.last_name AS manager_name\n        FROM departments d\n        LEFT JOIN employees e ON d.manager_id = e.employee_id;\n    \n    v_angajat_list angajat_list := angajat_list();\n    v_dept_info dept_info;\nBEGIN\n    FOR dept_rec IN dept_cursor LOOP\n        v_angajat_list.DELETE;\n        \n        SELECT angajat_info(\n                emp_data.employee_id,\n                emp_data.first_name,\n                emp_data.last_name,\n                emp_data.salary,\n                emp_data.ranking\n              )\n        BULK COLLECT INTO v_angajat_list\n        FROM (\n            SELECT e.employee_id,\n                   e.first_name,\n                   e.last_name,\n                   e.salary,\n                   DENSE_RANK() OVER (ORDER BY e.salary DESC) as ranking\n            FROM employees e\n            WHERE e.department_id = dept_rec.department_id\n        ) emp_data\n        WHERE emp_data.ranking <= 5\n        ORDER BY emp_data.ranking, emp_data.last_name, emp_data.first_name;\n        \n        v_dept_info := dept_info(\n            dept_rec.department_id,\n            dept_rec.department_name,\n            dept_rec.manager_name,\n            v_angajat_list\n        );\n        \n        PIPE ROW(v_dept_info);\n    END LOOP;\n    \n    RETURN;\nEXCEPTION\n    WHEN OTHERS THEN\n        RAISE_APPLICATION_ERROR(-20001, 'Eroare la extragerea datelor: ' || SQLERRM);\nEND get_department_top_employees;\n/
bb4b22cd-2014-4dfa-a915-53336fa69173:1765206932597:89:F:DECLARE\n    v_departamente dept_info_list;\n    v_counter_dept NUMBER := 0;\n    v_counter_emp NUMBER := 0;\nBEGIN\n    -- Obține datele din funcție\n    SELECT VALUE(d) \n    BULK COLLECT INTO v_departamente\n    FROM TABLE(get_department_top_employees()) d;\n    \n    -- Afișează header-ul\n    DBMS_OUTPUT.PUT_LINE('==============================================================================');\n    DBMS_OUTPUT.PUT_LINE('                   RAPORT - TOP 5 ANGAJATI PE DEPARTAMENTE');\n    DBMS_OUTPUT.PUT_LINE('==============================================================================');\n    DBMS_OUTPUT.PUT_LINE('');\n    \n    -- Iterează prin departamente\n    FOR i IN 1..v_departamente.COUNT LOOP\n        v_counter_dept := v_counter_dept + 1;\n        \n        DBMS_OUTPUT.PUT_LINE('DEPARTAMENT ' || v_counter_dept || ':');\n        DBMS_OUTPUT.PUT_LINE('------------');\n        DBMS_OUTPUT.PUT_LINE('ID Departament: ' || v_departamente(i).department_id);\n        DBMS_OUTPUT.PUT_LINE('Nume Departament: ' || v_departamente(i).department_name);\n        DBMS_OUTPUT.PUT_LINE('Manager: ' || NVL(v_departamente(i).manager_name, 'Necunoscut'));\n        DBMS_OUTPUT.PUT_LINE('');\n        \n        -- Verifică dacă sunt angajați\n        IF v_departamente(i).top_employees.COUNT > 0 THEN\n            DBMS_OUTPUT.PUT_LINE('TOP 5 ANGAJATI (după salariu):');\n            DBMS_OUTPUT.PUT_LINE('-----------------------------');\n            \n            -- Iterează prin angajații departamentului\n            FOR j IN 1..v_departamente(i).top_employees.COUNT LOOP\n                v_counter_emp := v_counter_emp + 1;\n                \n                DBMS_OUTPUT.PUT_LINE(\n                    '  ' || v_departamente(i).top_employees(j).ranking || '. ' ||\n                    v_departamente(i).top_employees(j).first_name || ' ' ||\n                    v_departamente(i).top_employees(j).last_name ||\n                    ' (ID: ' || v_departamente(i).top_employees(j).employee_id || ')' ||\n                    ' - Salariu: ' || TO_CHAR(v_departamente(i).top_employees(j).salary, '999,999,999.00') ||\n                    ' - Pozitie: ' || v_departamente(i).top_employees(j).ranking\n                );\n            END LOOP;\n        ELSE\n            DBMS_OUTPUT.PUT_LINE('NICIUN ANGAJAT ÎN ACEST DEPARTAMENT');\n        END IF;\n        \n        DBMS_OUTPUT.PUT_LINE('');\n        DBMS_OUTPUT.PUT_LINE('==============================================================================');\n        DBMS_OUTPUT.PUT_LINE('');\n    END LOOP;\n    \n    -- Afișează sumar\n    DBMS_OUTPUT.PUT_LINE('REZUMAT:');\n    DBMS_OUTPUT.PUT_LINE('--------');\n    DBMS_OUTPUT.PUT_LINE('Total departamente procesate: ' || v_counter_dept);\n    DBMS_OUTPUT.PUT_LINE('Total angajați afișați: ' || v_counter_emp);\n    \nEXCEPTION\n    WHEN OTHERS THEN\n        DBMS_OUTPUT.PUT_LINE('Eroare: ' || SQLERRM);\nEND;\n/
