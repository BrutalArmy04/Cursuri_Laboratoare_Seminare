cc192257-a468-495d-869c-1b6972825643:1765735232644:105:S:BEGIN\n    -- Planifica job-ul de marire a salariului cu 500 pentru angajatul 206\n    DBMS_JOB.SUBMIT(\n        job         => :job_num,                                  -- Identificator pentru job [cite: 1300]\n        what        => 'p_marire_salariu_id(206, 500);',          -- Codul PL/SQL de executat [cite: 1300]\n        next_date   => SYSDATE + (1 / 1440),                      -- Execută peste 1 minut (1/1440 din zi)\n        interval    => 'NULL'                                    -- Se execută o singură dată [cite: 1302]\n    );\n    COMMIT;\n    DBMS_OUTPUT.PUT_LINE('Job planificat cu succes. ID Job: ' || :job_num);\nEND;\n/
