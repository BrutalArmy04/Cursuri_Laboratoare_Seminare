53f35b18-9ebb-4113-b051-b5f85964dd1f:1763926879038:64:S:select * from excursie_sro;
5b016367-e559-4074-aeae-ea57c1507f6d:1763927674667:0:F:SELECT \n    e.cod_excursie_sro,\n    e.denumire,\n    CARDINALITY(e.orase) as numar_orase,\n    LISTAGG(o.column_value, ', ') WITHIN GROUP (ORDER BY o.column_value) as orase_vizitate\nFROM excursie_sro e,\n     TABLE(e.orase) o\nWHERE e.cod_excursie_sro = 1\nGROUP BY e.cod_excursie_sro, e.denumire, CARDINALITY(e.orase);
686a5e7a-5b2b-4b29-814d-a5cc9b16e078:1763927967175:0:F:CREATE TYPE tip_orase AS VARRAY(20) OF VARCHAR2(30);\n/
a524fa43-6d15-458f-b2b6-3d6bdda7252c:1763928204557:32:S:SELECT \n    e.cod_excursie_sro,\n    e.denumire,\n    COUNT(o.column_value) as numar_orase,\n    LISTAGG(o.column_value, ', ') WITHIN GROUP (ORDER BY o.column_value) as orase_vizitate\nFROM excursie_sro e,\n     TABLE(e.orase) o\nWHERE e.cod_excursie_sro = 1\nGROUP BY e.cod_excursie_sro, e.denumire;
6484e8ed-b1d7-44cd-a962-ef0428b6e079:1763928318821:0:F:SELECT \n    e.cod_excursie_sro,\n    e.denumire,\n    e.status,\n    CARDINALITY(e.orase) as numar_orase,\n    LISTAGG(o.column_value, ', ') WITHIN GROUP (ORDER BY o.column_value) as orase_vizitate\nFROM excursie_sro e,\n     TABLE(e.orase) o\nGROUP BY e.cod_excursie_sro, e.denumire, e.status, CARDINALITY(e.orase)\nORDER BY e.cod_excursie_sro;
59c49c6c-3698-47e5-a6c9-6e3df8e265cd:1763928342272:12:S:SELECT \n    e.cod_excursie_sro,\n    e.denumire,\n    e.status,\n    COUNT(o.column_value) as numar_orase,\n    LISTAGG(o.column_value, ', ') WITHIN GROUP (ORDER BY o.column_value) as orase_vizitate\nFROM excursie_sro e,\n     TABLE(e.orase) o\nGROUP BY e.cod_excursie_sro, e.denumire, e.status\nORDER BY e.cod_excursie_sro;
10cb7ed4-ea32-4a13-b775-324dbc0f85ab:1763928432795:0:F:UPDATE excursie_sro\nSET status = 'anulată'\nWHERE CARDINALITY(orase) = (\n    SELECT MIN(CARDINALITY(orase))\n    FROM excursie_sro\n    WHERE status = 'disponibilă'\n);
a5cb5988-d79b-4f8d-8366-d52a8d1d42e6:1763928488807:15:S:UPDATE excursie_sro e1\nSET status = 'anulată'\nWHERE (SELECT COUNT(*) FROM TABLE(e1.orase)) = (\n    SELECT MIN((SELECT COUNT(*) FROM TABLE(e2.orase)))\n    FROM excursie_sro e2\n    WHERE e2.status = 'disponibilă'\n);
