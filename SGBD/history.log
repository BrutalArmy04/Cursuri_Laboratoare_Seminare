efaabf77-8955-4fab-a496-acf027372f1c:1763814699568:454:S:SELECT\n    'CREATE TABLE ' || table_name || ' (' ||\n    LISTAGG(column_name || ' ' || data_type ||\n      CASE \n        WHEN data_type IN ('VARCHAR2', 'CHAR') \n        THEN '('||data_length||')'\n        WHEN data_type = 'NUMBER' AND data_precision IS NOT NULL \n        THEN '('||data_precision||','||data_scale||')'\n      END, \n    ', ') WITHIN GROUP (ORDER BY column_id)\n    || ');' AS ddl\nFROM user_tab_columns\nGROUP BY table_name;
a406d92b-cc61-4c32-836d-eaa4756ea09a:1763814909858:0:F:SELECT\n    'INSERT INTO ' || table_name || ' (' ||\n    LISTAGG(column_name, ', ') WITHIN GROUP (ORDER BY column_id) ||\n    ') VALUES (' ||\n    LISTAGG(\n        CASE \n          WHEN data_type LIKE '%CHAR%' THEN '''' || REPLACE(value, '''', '''''') || ''''\n          WHEN data_type LIKE '%DATE%' THEN 'TO_DATE(''' || TO_CHAR(value,'YYYY-MM-DD HH24:MI:SS') || ''',''YYYY-MM-DD HH24:MI:SS'')'\n          ELSE NVL(value, 'NULL')\n        END,\n        ', '\n    ) WITHIN GROUP (ORDER BY column_id)\n    || ');' AS insert_stmt\nFROM (\n    SELECT \n        t.table_name,\n        c.column_name,\n        c.data_type,\n        c.data_length,\n        c.data_precision,\n        c.data_scale,\n        col.column_id,\n        col.value\n    FROM user_tab_columns c\n    JOIN user_tables t ON t.table_name = c.table_name\n    JOIN (\n        SELECT table_name, column_name, column_id\n        FROM user_tab_columns\n    ) col\n      ON col.table_name = c.table_name AND col.column_name = c.column_name\n    LEFT JOIN (\n        SELECT table_name, column_name, to_char(column_value) AS value\n        FROM (\n            SELECT t.table_name, c.column_name, column_value\n            FROM user_tables t\n            JOIN user_tab_columns c ON t.table_name = c.table_name\n        )\n    ) vals ON vals.table_name = c.table_name AND vals.column_name = c.column_name\n)\nGROUP BY table_name;
a442711b-3b5d-4ebb-875d-075de92e0272:1763814935920:0:F:SELECT\n    'INSERT INTO ' || table_name || ' (' ||\n    LISTAGG(column_name, ', ') WITHIN GROUP (ORDER BY column_id) ||\n    ') VALUES (' ||\n    LISTAGG(\n        CASE \n          WHEN data_type LIKE '%CHAR%' THEN '''' || REPLACE(value, '''', '''''') || ''''\n          WHEN data_type LIKE '%DATE%' THEN 'TO_DATE(''' || TO_CHAR(value,'YYYY-MM-DD HH24:MI:SS') || ''',''YYYY-MM-DD HH24:MI:SS'')'\n          ELSE NVL(value, 'NULL')\n        END,\n        ', '\n    ) WITHIN GROUP (ORDER BY column_id)\n    || ');' AS insert_stmt\nFROM (\n    SELECT \n        t.table_name,\n        c.column_name,\n        c.data_type,\n        c.data_length,\n        c.data_precision,\n        c.data_scale,\n        col.column_id,\n        col.value\n    FROM user_tab_columns c\n    JOIN user_tables t ON t.table_name = c.table_name\n    JOIN (\n        SELECT table_name, column_name, column_id\n        FROM user_tab_columns\n    ) col\n      ON col.table_name = c.table_name AND col.column_name = c.column_name\n    LEFT JOIN (\n        SELECT table_name, column_name, to_char(column_value) AS value\n        FROM (\n            SELECT t.table_name, c.column_name, column_value\n            FROM user_tables t\n            JOIN user_tab_columns c ON t.table_name = c.table_name\n        )\n    ) vals ON vals.table_name = c.table_name AND vals.column_name = c.column_name\n)\nGROUP BY table_name;
