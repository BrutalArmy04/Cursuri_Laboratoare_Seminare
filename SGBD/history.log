48724a83-894e-4a5b-ae40-0c623b151db4:1763919746086:0:F:SELECT\n    'INSERT INTO FACTURI_COPY (ID_FACTURA, ID_CLIENT, DATA_EMITERII, SUMA_TOTALA, ID_TIP_PLATA) VALUES ('\n    || NVL(TO_CHAR(ID_FACTURA), 'NULL') || ', '\n    || NVL(TO_CHAR(ID_CLIENT), 'NULL') || ', '\n    || CASE\n         WHEN DATA_EMITERII IS NULL THEN 'NULL'\n         ELSE '''' || TO_CHAR(DATA_EMITERII, 'YYYY-MM-DD HH24:MI:SS') || ''''\n       END || ', '\n    || NVL(TO_CHAR(SUMA_TOTALA), 'NULL') || ', '\n    || NVL(TO_CHAR(ID_TIP_PLATA), 'NULL')\n    || ');' AS insert_line\nFROM FACTURI_COPY;
