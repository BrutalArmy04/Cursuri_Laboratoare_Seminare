6c211a70-6101-4ec8-9b9d-f752548c8059:1764177784677:51:S:DECLARE\n   CURSOR c_jobs IS\n      SELECT job_title\n      FROM jobs;\n   \n   TYPE emp_rec_type IS RECORD (\n      first_name employees.first_name%TYPE,\n      last_name employees.last_name%TYPE,\n      salary employees.salary%TYPE\n   );\n   \n   TYPE emp_table_type IS TABLE OF emp_rec_type;\n   \n   v_employees emp_table_type;\n    v_job_title jobs.job_title%TYPE;\nBEGIN\n   FOR job_rec IN c_jobs LOOP\n        v_job_title := job_rec.job_title;\n        SELECT first_name, last_name, salary\n        BULK COLLECT INTO v_employees\n        FROM employees\n        WHERE job_id = (SELECT job_id FROM jobs WHERE job_title = v_job_title);\n        \n        DBMS_OUTPUT.PUT_LINE('Job Title: ' || v_job_title);\n        \n        IF v_employees.COUNT = 0 THEN\n             DBMS_OUTPUT.PUT_LINE('  No employees currently hold this job.');\n        ELSE\n             FOR i IN 1 .. v_employees.COUNT LOOP\n                DBMS_OUTPUT.PUT_LINE('  ' || v_employees(i).first_name || ' ' || v_employees(i).last_name || \n                                     ' - Salary: ' || v_employees(i).salary);\n             END LOOP;\n        END IF;\n     END LOOP;\nEND;\n/
ed41e890-18d9-423f-9d28-ef52a0041593:1764178612641:0:S:set SERVEROUTPUT ON;
ce1b03ac-aca6-47ba-be68-4cc21a168dbf:1764178612768:0:S:SET SERVEROUTPUT ON
5365f6c7-67b0-4fbc-b246-6e9fe4368fe0:1764178623127:75:S:DECLARE\n    TYPE ref_cursor IS REF CURSOR;\n    v_cursor_angajati ref_cursor;\n    \n    v_job_title   jobs.job_title%TYPE; \n    v_nume        employees.last_name%TYPE; \n    v_salariu     employees.salary%TYPE; \n    sem       BOOLEAN;\n    \n    -- Cursor principal cu REF CURSOR imbricat\n    CURSOR c_jobs IS \n        SELECT j.job_title,\n               CURSOR(SELECT e.last_name, e.salary \n                      FROM employees e \n                      WHERE e.job_id = j.job_id) \n        FROM jobs j;\nBEGIN\n    OPEN c_jobs;\n    LOOP\n        FETCH c_jobs INTO v_job_title, v_cursor_angajati;\n        EXIT WHEN c_jobs%NOTFOUND;\n        \n        DBMS_OUTPUT.PUT_LINE('Job: ' || v_job_title);\n        sem := FALSE;\n        \n        LOOP\n            FETCH v_cursor_angajati INTO v_nume, v_salariu;\n            EXIT WHEN v_cursor_angajati%NOTFOUND;\n            \n            sem := TRUE;\n            DBMS_OUTPUT.PUT_LINE('   Angajat: ' || v_nume || ', Salariu: ' || v_salariu);\n        END LOOP;\n        \n        IF NOT sem THEN\n            DBMS_OUTPUT.PUT_LINE('   Nu exista angajati');\n        END IF;\n        \n        DBMS_OUTPUT.PUT_LINE(''); -- Linie goală\n    END LOOP;\n    \n    CLOSE c_jobs;\nEND;\n/
ee32101d-947b-46b6-b252-bf1d815f2860:1764364296907:100:S:DECLARE\n    -- Cursor care include și numărul de angajați direct\n    CURSOR c_joburi_detaliate IS\n        SELECT j.job_id, \n               j.job_title,\n               COUNT(e.employee_id) as nr_angajati,\n               NVL(SUM(e.salary), 0) as venit_total,\n               NVL(AVG(e.salary), 0) as venit_mediu\n        FROM jobs j\n        LEFT JOIN employees e ON j.job_id = e.job_id\n        GROUP BY j.job_id, j.job_title\n        ORDER BY j.job_title;\n    \n    -- Cursor pentru angajații unui job\n    CURSOR c_angajati (p_job_id VARCHAR2) IS\n        SELECT first_name, last_name, salary\n        FROM employees\n        WHERE job_id = p_job_id\n        ORDER BY last_name, first_name;\n    \n    -- Variabile\n    v_nr_ordine NUMBER;\n    v_nr_total_angajati NUMBER := 0;\n    v_venit_total_global NUMBER := 0;\n\nBEGIN\n    -- Calcule globale\n    SELECT COUNT(*), NVL(SUM(salary), 0)\n    INTO v_nr_total_angajati, v_venit_total_global\n    FROM employees;\n    \n    DBMS_OUTPUT.PUT_LINE('=== RAPORT ANGAJATI PE JOB ===');\n    DBMS_OUTPUT.PUT_LINE('');\n    \n    -- Parcurgere job-uri cu detalii\n    FOR job_rec IN c_joburi_detaliate LOOP\n        DBMS_OUTPUT.PUT_LINE('JOB: ' || job_rec.job_title);\n        DBMS_OUTPUT.PUT_LINE('----------------------------------------');\n        \n        v_nr_ordine := 0;\n        \n        -- Verificare existență angajați\n        IF job_rec.nr_angajati > 0 THEN\n            -- Afișare angajați cu număr de ordine\n            FOR angajat_rec IN c_angajati(job_rec.job_id) LOOP\n                v_nr_ordine := v_nr_ordine + 1;\n                DBMS_OUTPUT.PUT_LINE(\n                    RPAD(v_nr_ordine || '.', 4) || \n                    RPAD(angajat_rec.first_name || ' ' || angajat_rec.last_name, 30) ||\n                    TO_CHAR(angajat_rec.salary, '999,999.00')\n                );\n            END LOOP;\n            \n            DBMS_OUTPUT.PUT_LINE('----------------------------------------');\n        ELSE\n            DBMS_OUTPUT.PUT_LINE('*** Niciun angajat pe acest job ***');\n        END IF;\n        \n        -- Afișare statistici job (calculate direct în cursor)\n        DBMS_OUTPUT.PUT_LINE('Statistici job:');\n        DBMS_OUTPUT.PUT_LINE('- Numar angajati: ' || job_rec.nr_angajati);\n        DBMS_OUTPUT.PUT_LINE('- Venit total lunar: ' || TO_CHAR(job_rec.venit_total, '999,999,999.00'));\n        DBMS_OUTPUT.PUT_LINE('- Venit mediu lunar: ' || TO_CHAR(job_rec.venit_mediu, '999,999.00'));\n        \n        DBMS_OUTPUT.PUT_LINE('');\n        DBMS_OUTPUT.PUT_LINE('');\n        \n    END LOOP;\n    \n    -- Afișare rezumat final\n    DBMS_OUTPUT.PUT_LINE('=== REZUMAT FINAL ===');\n    DBMS_OUTPUT.PUT_LINE('Total general angajati: ' || v_nr_total_angajati);\n    DBMS_OUTPUT.PUT_LINE('Venit total lunar general: ' || TO_CHAR(v_venit_total_global, '999,999,999.00'));\n    DBMS_OUTPUT.PUT_LINE('Venit mediu lunar general: ' || TO_CHAR(v_venit_total_global/NULLIF(v_nr_total_angajati,0), '999,999.00'));\n    \nEND;\n/
