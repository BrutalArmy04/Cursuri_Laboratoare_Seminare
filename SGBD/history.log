8a009cf3-a906-46bf-91b0-b294af5379a8:1765814282570:3167:F:CREATE OR REPLACE TRIGGER trg_check_salary_range\nBEFORE INSERT OR UPDATE OF salary ON emp_sro\nFOR EACH ROW\nDECLARE\n    v_min_sal jobs.min_salary%TYPE;\n    v_max_sal jobs.max_salary%TYPE;\nBEGIN\n    -- 1. Selectam limitele salariale pentru job-ul angajatului\n    -- Folosim :NEW.job_id pentru a sti ce job are (sau va avea) angajatul\n    SELECT min_salary, max_salary\n    INTO v_min_sal, v_max_sal\n    FROM jobs\n    WHERE job_id = :NEW.job_id;\n\n    -- 2. Verificam daca salariul este mai mic decat minimul\n    IF :NEW.salary < v_min_sal THEN\n        RAISE_APPLICATION_ERROR(-20003, \n            'Eroare: Salariul (' || :NEW.salary || ') este mai mic decat minimul admis (' || v_min_sal || ') pentru jobul ' || :NEW.job_id);\n            \n    -- 3. Verificam daca salariul este mai mare decat maximul\n    ELSIF :NEW.salary > v_max_sal THEN\n        RAISE_APPLICATION_ERROR(-20004, \n            'Eroare: Salariul (' || :NEW.salary || ') depaseste maximul admis (' || v_max_sal || ') pentru jobul ' || :NEW.job_id);\n    END IF;\n\nEXCEPTION\n    -- Tratarea cazului in care job_id-ul nu exista in tabela jobs\n    WHEN NO_DATA_FOUND THEN\n        RAISE_APPLICATION_ERROR(-20005, 'Eroare: Job-ul specificat nu a fost gasit in tabela JOBS.');\nEND;\n/
