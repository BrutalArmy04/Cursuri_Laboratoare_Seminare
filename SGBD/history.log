b2731439-2370-4d64-ab28-634d8df01af9:1763928966665:814:S:DECLARE\n    TYPE varray_tip_plata IS VARRAY(100) OF tip_plata%ROWTYPE;\n    TYPE nested_table_tip_plata IS TABLE OF tip_plata%ROWTYPE;\n    TYPE index_by_table_tip_plata IS TABLE OF tip_plata%ROWTYPE INDEX BY PLS_INTEGER;\n\n    v_varray varray_tip_plata;\n    v_nested_table nested_table_tip_plata;\n    v_index_by_table index_by_table_tip_plata;\n\n    CURSOR c_tip_plata IS\n        SELECT * FROM tip_plata;\n\n    l_start_time NUMBER;\n    l_end_time NUMBER;\n    l_total_time NUMBER := 0;\n    l_runs NUMBER := 10000;\n    l_avg_time NUMBER;\nBEGIN\n    -- VARRAY test\n    FOR run_counter IN 1..l_runs LOOP\n        l_start_time := DBMS_UTILITY.GET_TIME;\n\n        v_varray := varray_tip_plata();\n        FOR rec IN c_tip_plata LOOP\n            v_varray.EXTEND;\n            v_varray(v_varray.COUNT) := rec;\n        END LOOP;\n\n        l_end_time := DBMS_UTILITY.GET_TIME;\n        l_total_time := l_total_time + (l_end_time - l_start_time);\n    END LOOP;\n    l_avg_time := (l_total_time / l_runs) / 100;\n    DBMS_OUTPUT.PUT_LINE('VARRAY - Număr teste: ' || l_runs);\n    DBMS_OUTPUT.PUT_LINE('VARRAY - Timp mediu de execuție: ' || l_avg_time || ' secunde');\nend;\n/
60ce8334-4896-4724-87dd-54b6222eabfe:1763928968821:743:S:DECLARE\n    TYPE varray_tip_plata IS VARRAY(100) OF tip_plata%ROWTYPE;\n    TYPE nested_table_tip_plata IS TABLE OF tip_plata%ROWTYPE;\n    TYPE index_by_table_tip_plata IS TABLE OF tip_plata%ROWTYPE INDEX BY PLS_INTEGER;\n\n    v_varray varray_tip_plata;\n    v_nested_table nested_table_tip_plata;\n    v_index_by_table index_by_table_tip_plata;\n\n    CURSOR c_tip_plata IS\n        SELECT * FROM tip_plata;\n\n    l_start_time NUMBER;\n    l_end_time NUMBER;\n    l_total_time NUMBER := 0;\n    l_runs NUMBER := 10000;\n    l_avg_time NUMBER;\nBEGIN\n    -- Nested Table test\n    FOR run_counter IN 1..l_runs LOOP\n        l_start_time := DBMS_UTILITY.GET_TIME;\n\n        v_nested_table := nested_table_tip_plata();\n        FOR rec IN c_tip_plata LOOP\n            v_nested_table.EXTEND;\n            v_nested_table(v_nested_table.COUNT) := rec;\n        END LOOP;\n\n        l_end_time := DBMS_UTILITY.GET_TIME;\n        l_total_time := l_total_time + (l_end_time - l_start_time);\n    END LOOP;\n    l_avg_time := (l_total_time / l_runs) / 100;\n    DBMS_OUTPUT.PUT_LINE('Nested Table - Număr teste: ' || l_runs);\n    DBMS_OUTPUT.PUT_LINE('Nested Table - Timp mediu de execuție: ' || l_avg_time || ' secunde');\nend;\n/
f024b1cf-05f1-44bb-986c-7e7c85044242:1763928970897:709:S:DECLARE\n    TYPE varray_tip_plata IS VARRAY(100) OF tip_plata%ROWTYPE;\n    TYPE nested_table_tip_plata IS TABLE OF tip_plata%ROWTYPE;\n    TYPE index_by_table_tip_plata IS TABLE OF tip_plata%ROWTYPE INDEX BY PLS_INTEGER;\n\n    v_varray varray_tip_plata;\n    v_nested_table nested_table_tip_plata;\n    v_index_by_table index_by_table_tip_plata;\n\n    CURSOR c_tip_plata IS\n        SELECT * FROM tip_plata;\n\n    l_start_time NUMBER;\n    l_end_time NUMBER;\n    l_total_time NUMBER := 0;\n    l_runs NUMBER := 10000;\n    l_avg_time NUMBER;\nBEGIN\n    -- Indexed By Table test\n    FOR run_counter IN 1..l_runs LOOP\n        l_start_time := DBMS_UTILITY.GET_TIME;\n\n        v_index_by_table := index_by_table_tip_plata();\n        DECLARE\n            idx PLS_INTEGER := 0;\n        BEGIN\n            FOR rec IN c_tip_plata LOOP\n                idx := idx + 1;\n                v_index_by_table(idx) := rec;\n            END LOOP;\n        END;\n\n        l_end_time := DBMS_UTILITY.GET_TIME;\n        l_total_time := l_total_time + (l_end_time - l_start_time);\n    END LOOP;\n    l_avg_time := (l_total_time / l_runs) / 100;\n    DBMS_OUTPUT.PUT_LINE('Indexed By Table - Număr teste: ' || l_runs);\n    DBMS_OUTPUT.PUT_LINE('Indexed By Table - Timp mediu de execuție: ' || l_avg_time || ' secunde');\nend;\n/
11e01acf-e9ab-4d66-8063-877e3a60c480:1763929705505:31:S:CREATE TABLE dummy_table (\n    id NUMBER,\n    name VARCHAR2(100),\n    value NUMBER\n);
d2aa8bef-a305-4be1-b8ea-472e8e901263:1763929706147:1151:S:BEGIN\n    FOR i IN 1..10000 LOOP\n        INSERT INTO dummy_table VALUES (\n            i,                              -- id (sequential)\n            'Name_' || i,                   -- name\n            ROUND(DBMS_RANDOM.VALUE(1,1000)) -- random value between 1-1000\n        );\n    END LOOP;\n    COMMIT;\nEND;\n/
