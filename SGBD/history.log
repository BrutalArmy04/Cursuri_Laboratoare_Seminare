8a4a0ffe-524a-4237-9d32-0bc0638c5d27:1763924947709:148:S:DECLARE\n  -- Collection type definitions\n  TYPE rec_type IS RECORD (\n    id_factura facturi.id_factura%TYPE,\n    id_casa facturi.id_casa%TYPE,\n    id_client facturi.id_client%TYPE,\n    adresa_livrare facturi.adresa_livrare%TYPE,\n    adresa_facturare facturi.adresa_facturare%TYPE,\n    data facturi.data%TYPE\n  );\n  \n  -- Index-by table\n  TYPE tab_ind IS TABLE OF rec_type INDEX BY PLS_INTEGER;\n  \n  -- Nested table\n  TYPE tab_nested IS TABLE OF rec_type;\n  \n  -- Varray (limited to 200 elements based on your data sample)\n  TYPE tab_varray IS VARRAY(200) OF rec_type;\n  \n  -- Collection instances\n  t_ind tab_ind;\n  t_nested tab_nested;\n  t_varray tab_varray;\n  \n  -- Timing variables\n  l_start_time NUMBER;\n  l_end_time NUMBER;\n  l_time_ind NUMBER := 0;\n  l_time_nested NUMBER := 0;\n  l_time_varray NUMBER := 0;\n  \n  -- Memory variables\n  l_mem_start NUMBER;\n  l_mem_end NUMBER;\n  l_mem_ind NUMBER := 0;\n  l_mem_nested NUMBER := 0;\n  l_mem_varray NUMBER := 0;\n  \n  -- Test control\n  l_runs NUMBER := 10;\n  l_counter PLS_INTEGER;\n  \n  -- Function to get current memory usage\n  FUNCTION get_memory RETURN NUMBER IS\n    l_mem NUMBER;\n  BEGIN\n    SELECT VALUE INTO l_mem \n    FROM V$MYSTAT m, V$STATNAME s \n    WHERE m.STATISTIC# = s.STATISTIC# \n    AND s.NAME = 'session pga memory';\n    RETURN l_mem;\n  END get_memory;\n\nBEGIN\n  DBMS_OUTPUT.PUT_LINE('=== COLLECTION PERFORMANCE COMPARISON ===');\n  DBMS_OUTPUT.PUT_LINE('Testing with ' || l_runs || ' runs per collection type');\n  DBMS_OUTPUT.PUT_LINE('=========================================');\n  \n  -- Test 1: Index-by Table\n  DBMS_OUTPUT.PUT_LINE(CHR(10) || '1. INDEX-BY TABLE TEST:');\n  l_mem_start := get_memory();\n  \n  FOR run IN 1..l_runs LOOP\n    l_start_time := DBMS_UTILITY.GET_TIME;\n    \n    -- Populate collection\n    l_counter := 0;\n    FOR rec IN (SELECT id_factura, id_casa, id_client, adresa_livrare, adresa_facturare, data \n                FROM facturi) \n    LOOP\n      l_counter := l_counter + 1;\n      t_ind(l_counter) := rec;\n    END LOOP;\n    \n    -- Access test\n    FOR i IN 1..t_ind.COUNT LOOP\n      IF t_ind(i).id_factura IS NULL THEN\n        NULL; -- Dummy operation\n      END IF;\n    END LOOP;\n    \n    l_end_time := DBMS_UTILITY.GET_TIME;\n    l_time_ind := l_time_ind + (l_end_time - l_start_time);\n    \n    -- Clear collection for next run\n    t_ind.DELETE;\n  END LOOP;\n  \n  l_mem_end := get_memory();\n  l_mem_ind := l_mem_end - l_mem_start;\n  \n  -- Test 2: Nested Table\n  DBMS_OUTPUT.PUT_LINE(CHR(10) || '2. NESTED TABLE TEST:');\n  l_mem_start := get_memory();\n  \n  FOR run IN 1..l_runs LOOP\n    l_start_time := DBMS_UTILITY.GET_TIME;\n    \n    -- Populate collection\n    SELECT id_factura, id_casa, id_client, adresa_livrare, adresa_facturare, data \n    BULK COLLECT INTO t_nested\n    FROM facturi;\n    \n    -- Access test\n    FOR i IN 1..t_nested.COUNT LOOP\n      IF t_nested(i).id_factura IS NULL THEN\n        NULL; -- Dummy operation\n      END IF;\n    END LOOP;\n    \n    l_end_time := DBMS_UTILITY.GET_TIME;\n    l_time_nested := l_time_nested + (l_end_time - l_start_time);\n    \n    -- Clear collection for next run\n    t_nested := NULL;\n  END LOOP;\n  \n  l_mem_end := get_memory();\n  l_mem_nested := l_mem_end - l_mem_start;\n  \n  -- Test 3: Varray\n  DBMS_OUTPUT.PUT_LINE(CHR(10) || '3. VARRAY TEST:');\n  l_mem_start := get_memory();\n  \n  FOR run IN 1..l_runs LOOP\n    l_start_time := DBMS_UTILITY.GET_TIME;\n    \n    -- Populate collection (must use loop for varray)\n    l_counter := 0;\n    t_varray := tab_varray();\n    \n    FOR rec IN (SELECT id_factura, id_casa, id_client, adresa_livrare, adresa_facturare, data \n                FROM facturi) \n    LOOP\n      l_counter := l_counter + 1;\n      IF l_counter > t_varray.LIMIT THEN\n        EXIT; -- Respect varray limit\n      END IF;\n      t_varray.EXTEND;\n      t_varray(l_counter) := rec;\n    END LOOP;\n    \n    -- Access test\n    FOR i IN 1..t_varray.COUNT LOOP\n      IF t_varray(i).id_factura IS NULL THEN\n        NULL; -- Dummy operation\n      END IF;\n    END LOOP;\n    \n    l_end_time := DBMS_UTILITY.GET_TIME;\n    l_time_varray := l_time_varray + (l_end_time - l_start_time);\n    \n    -- Clear collection for next run\n    t_varray := NULL;\n  END LOOP;\n  \n  l_mem_end := get_memory();\n  l_mem_varray := l_mem_end - l_mem_start;\n  \n  -- RESULTS SUMMARY\n  DBMS_OUTPUT.PUT_LINE(CHR(10) || '=== PERFORMANCE RESULTS SUMMARY ===');\n  DBMS_OUTPUT.PUT_LINE('Collection Type     | Avg Time (s) | Memory (KB) | Records');\n  DBMS_OUTPUT.PUT_LINE('--------------------|--------------|-------------|---------');\n  \n  DBMS_OUTPUT.PUT_LINE('Index-by Table      | ' || \n    TO_CHAR((l_time_ind/l_runs)/100, '9990.0000') || '     | ' ||\n    TO_CHAR(l_mem_ind/1024, '99990') || '      | ' || l_counter);\n    \n  DBMS_OUTPUT.PUT_LINE('Nested Table        | ' || \n    TO_CHAR((l_time_nested/l_runs)/100, '9990.0000') || '     | ' ||\n    TO_CHAR(l_mem_nested/1024, '99990') || '      | ' || l_counter);\n    \n  DBMS_OUTPUT.PUT_LINE('Varray              | ' || \n    TO_CHAR((l_time_varray/l_runs)/100, '9990.0000') || '     | ' ||\n    TO_CHAR(l_mem_varray/1024, '99990') || '      | ' || t_varray.LIMIT);\n  \n  -- Additional Analysis\n  DBMS_OUTPUT.PUT_LINE(CHR(10) || '=== ADDITIONAL ANALYSIS ===');\n  \n  -- Fastest collection\n  IF l_time_ind <= l_time_nested AND l_time_ind <= l_time_varray THEN\n    DBMS_OUTPUT.PUT_LINE('Fastest: Index-by Table');\n  ELSIF l_time_nested <= l_time_ind AND l_time_nested <= l_time_varray THEN\n    DBMS_OUTPUT.PUT_LINE('Fastest: Nested Table');\n  ELSE\n    DBMS_OUTPUT.PUT_LINE('Fastest: Varray');\n  END IF;\n  \n  -- Most memory efficient\n  IF l_mem_ind <= l_mem_nested AND l_mem_ind <= l_mem_varray THEN\n    DBMS_OUTPUT.PUT_LINE('Most Memory Efficient: Index-by Table');\n  ELSIF l_mem_nested <= l_mem_ind AND l_mem_nested <= l_mem_varray THEN\n    DBMS_OUTPUT.PUT_LINE('Most Memory Efficient: Nested Table');\n  ELSE\n    DBMS_OUTPUT.PUT_LINE('Most Memory Efficient: Varray');\n  END IF;\n  \n  -- Performance differences\n  DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Performance Differences:');\n  DBMS_OUTPUT.PUT_LINE('Nested Table vs Index-by: ' || \n    TO_CHAR(((l_time_nested - l_time_ind)/l_time_ind * 100), '9990.0') || '%');\n  DBMS_OUTPUT.PUT_LINE('Varray vs Index-by: ' || \n    TO_CHAR(((l_time_varray - l_time_ind)/l_time_ind * 100), '9990.0') || '%');\n    \nEXCEPTION\n  WHEN OTHERS THEN\n    DBMS_OUTPUT.PUT_LINE('Error: ' || SQLERRM);\nEND;\n/
