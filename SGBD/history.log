5247f5b0-b0d5-4f5f-a097-2e970f7006f0:1765206496216:42:F:CREATE OR REPLACE FUNCTION get_department_top_employees\nRETURN dept_info_list PIPELINED\nIS\n    CURSOR dept_cursor IS\n        SELECT d.department_id,\n               d.department_name,\n               e.first_name || ' ' || e.last_name AS manager_name\n        FROM departments d\n        LEFT JOIN employees e ON d.manager_id = e.employee_id;\n    \n    v_angajat_list angajat_list := angajat_list(); -- inițializare\n    v_dept_info dept_info;\nBEGIN\n    FOR dept_rec IN dept_cursor LOOP\n        -- Golește colecția pentru fiecare departament\n        v_angajat_list.DELETE;\n        \n        -- Select top 5 employees by salary for each department\n        -- Using DENSE_RANK to handle ties in salary\n        SELECT angajat_info(\n                emp_data.employee_id,\n                emp_data.first_name,\n                emp_data.last_name,\n                emp_data.salary,\n                emp_data.ranking\n              )\n        BULK COLLECT INTO v_angajat_list\n        FROM (\n            SELECT e.employee_id,\n                   e.first_name,\n                   e.last_name,\n                   e.salary,\n                   DENSE_RANK() OVER (ORDER BY e.salary DESC) as ranking\n            FROM employees e\n            WHERE e.department_id = dept_rec.department_id\n        ) emp_data\n        WHERE emp_data.ranking <= 5\n        ORDER BY emp_data.ranking, emp_data.last_name, emp_data.first_name;\n        \n        -- Create department info object\n        v_dept_info := dept_info(\n            dept_rec.department_id,\n            dept_rec.department_name,\n            dept_rec.manager_name,\n            v_angajat_list\n        );\n        \n        PIPE ROW(v_dept_info);\n    END LOOP;\n    \n    RETURN;\nEXCEPTION\n    WHEN OTHERS THEN\n        RAISE_APPLICATION_ERROR(-20001, 'Eroare la extragerea datelor: ' || SQLERRM);\nEND get_department_top_employees;\n/
