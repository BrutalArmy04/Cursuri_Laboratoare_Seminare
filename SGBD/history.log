9f592cbb-fc95-43eb-bff1-e719016550a5:1763923570130:15:S:commit;
bdd30ece-20cb-4eeb-9bb9-00e9f1af0214:1763923583786:100:S:select * from facturi;
65f02d2f-3b70-46ce-9966-28e3ad2128f6:1763923583979:10:S:select * from tip_plata;
fc526b39-8625-4357-b7ec-3e1fa2cd78fb:1763923628654:15:S:DECLARE \n  TYPE tab_ind IS TABLE OF tip_plata.descriere%TYPE \n       INDEX BY PLS_INTEGER; \n  t    tab_ind; \n  l_start_time NUMBER;\n  l_end_time NUMBER;\n  l_elapsed_time NUMBER;\nBEGIN \n  -- Start timing\n  l_start_time := DBMS_UTILITY.GET_TIME;\n  \n  -- atribuire valori \n  DELETE FROM tip_plata \n  WHERE  id_tip_plata NOT IN (SELECT id_tip_plata FROM facturi) \n  RETURNING descriere BULK COLLECT INTO t; \n  \n  -- End timing\n  l_end_time := DBMS_UTILITY.GET_TIME;\n  l_elapsed_time := (l_end_time - l_start_time) / 100; -- Convert to seconds\n  \n  --parcurgere \n  DBMS_OUTPUT.PUT_LINE('Tabloul are ' || t.COUNT || ' elemente:');\n  DBMS_OUTPUT.PUT_LINE('Execution time: ' || l_elapsed_time || ' seconds');\n  \n  FOR i IN t.FIRST..t.LAST LOOP \n    DBMS_OUTPUT.PUT_LINE(t(i)); \n  END LOOP; \n  \n  ROLLBACK; \nEND;\n/
550f055c-3a7d-4473-ae29-4ce1be1c19c1:1763923639823:68:S:select * from facturi;
04aff919-cd00-4085-bff7-7b991fb607bb:1763923639965:4:S:select * from tip_plata;
680ba09b-46ab-4a13-ba15-419e2d43b031:1763923662306:15:S:DECLARE \n  TYPE tab_ind IS TABLE OF tip_plata.descriere%TYPE \n       INDEX BY PLS_INTEGER; \n  t    tab_ind; \n  l_start_time TIMESTAMP;\n  l_end_time TIMESTAMP;\n  l_elapsed_time INTERVAL DAY TO SECOND;\nBEGIN \n  -- Start timing\n  l_start_time := SYSTIMESTAMP;\n  \n  -- atribuire valori \n  DELETE FROM tip_plata \n  WHERE  id_tip_plata NOT IN (SELECT id_tip_plata FROM facturi) \n  RETURNING descriere BULK COLLECT INTO t; \n  \n  -- End timing\n  l_end_time := SYSTIMESTAMP;\n  l_elapsed_time := l_end_time - l_start_time;\n  \n  --parcurgere \n  DBMS_OUTPUT.PUT_LINE('Tabloul are ' || t.COUNT || ' elemente:');\n  DBMS_OUTPUT.PUT_LINE('Execution time: ' || EXTRACT(SECOND FROM l_elapsed_time) || ' seconds');\n  DBMS_OUTPUT.PUT_LINE('Execution time (milliseconds): ' || (EXTRACT(SECOND FROM l_elapsed_time) * 1000));\n  \n  FOR i IN t.FIRST..t.LAST LOOP \n    DBMS_OUTPUT.PUT_LINE(t(i)); \n  END LOOP; \n  \n  ROLLBACK; \nEND;\n/
1ab8fbd7-9dc2-46f8-b38c-6519977de1f8:1763923719571:57:S:DECLARE \n  TYPE tab_ind IS TABLE OF tip_plata.descriere%TYPE \n       INDEX BY PLS_INTEGER; \n  t    tab_ind; \n  l_start_time NUMBER;\n  l_end_time NUMBER;\n  l_total_time NUMBER := 0;\n  l_runs NUMBER := 5; -- Number of test runs\n  l_avg_time NUMBER;\nBEGIN \n  \n  FOR run_counter IN 1..l_runs LOOP\n    -- Start timing\n    l_start_time := DBMS_UTILITY.GET_TIME;\n    \n    -- atribuire valori \n    DELETE FROM tip_plata \n    WHERE  id_tip_plata NOT IN (SELECT id_tip_plata FROM facturi) \n    RETURNING descriere BULK COLLECT INTO t; \n    \n    -- End timing\n    l_end_time := DBMS_UTILITY.GET_TIME;\n    l_total_time := l_total_time + (l_end_time - l_start_time);\n    \n    DBMS_OUTPUT.PUT_LINE('Run ' || run_counter || ': ' || ((l_end_time - l_start_time)/100) || ' seconds');\n    \n    ROLLBACK; \n  END LOOP;\n  \n  l_avg_time := (l_total_time / l_runs) / 100;\n  \n  DBMS_OUTPUT.PUT_LINE('=== PERFORMANCE RESULTS ===');\n  DBMS_OUTPUT.PUT_LINE('Number of runs: ' || l_runs);\n  DBMS_OUTPUT.PUT_LINE('Average execution time: ' || l_avg_time || ' seconds');\n  DBMS_OUTPUT.PUT_LINE('Total time for all runs: ' || (l_total_time/100) || ' seconds');\n  \n  -- Show results from last run\n  DBMS_OUTPUT.PUT_LINE('Tabloul are ' || t.COUNT || ' elemente:');\n  FOR i IN t.FIRST..t.LAST LOOP \n    DBMS_OUTPUT.PUT_LINE(t(i)); \n  END LOOP; \nEND;\n/
7c467170-f80c-4930-8cbc-44984cda0a5f:1763923736209:161:S:DECLARE \n  TYPE tab_ind IS TABLE OF tip_plata.descriere%TYPE \n       INDEX BY PLS_INTEGER; \n  t    tab_ind; \n  l_start_time NUMBER;\n  l_end_time NUMBER;\n  l_total_time NUMBER := 0;\n  l_runs NUMBER := 100; -- Number of test runs\n  l_avg_time NUMBER;\nBEGIN \n  \n  FOR run_counter IN 1..l_runs LOOP\n    -- Start timing\n    l_start_time := DBMS_UTILITY.GET_TIME;\n    \n    -- atribuire valori \n    DELETE FROM tip_plata \n    WHERE  id_tip_plata NOT IN (SELECT id_tip_plata FROM facturi) \n    RETURNING descriere BULK COLLECT INTO t; \n    \n    -- End timing\n    l_end_time := DBMS_UTILITY.GET_TIME;\n    l_total_time := l_total_time + (l_end_time - l_start_time);\n    \n    DBMS_OUTPUT.PUT_LINE('Run ' || run_counter || ': ' || ((l_end_time - l_start_time)/100) || ' seconds');\n    \n    ROLLBACK; \n  END LOOP;\n  \n  l_avg_time := (l_total_time / l_runs) / 100;\n  \n  DBMS_OUTPUT.PUT_LINE('=== PERFORMANCE RESULTS ===');\n  DBMS_OUTPUT.PUT_LINE('Number of runs: ' || l_runs);\n  DBMS_OUTPUT.PUT_LINE('Average execution time: ' || l_avg_time || ' seconds');\n  DBMS_OUTPUT.PUT_LINE('Total time for all runs: ' || (l_total_time/100) || ' seconds');\n  \n  -- Show results from last run\n  DBMS_OUTPUT.PUT_LINE('Tabloul are ' || t.COUNT || ' elemente:');\n  FOR i IN t.FIRST..t.LAST LOOP \n    DBMS_OUTPUT.PUT_LINE(t(i)); \n  END LOOP; \nEND;\n/
24adb1ac-0af8-4870-aee1-5ff682c4531f:1763924023499:192:S:DECLARE \n  TYPE rec IS RECORD (id tip_plata.id_tip_plata%TYPE, \n                      den tip_plata.descriere%TYPE); \n  TYPE tab_ind IS TABLE OF rec \n       INDEX BY PLS_INTEGER; \n  t    tab_ind; \n  l_start_time NUMBER;\n  l_end_time NUMBER;\n  l_total_time NUMBER := 0;\n  l_runs NUMBER := 100; -- Number of test runs\n  l_avg_time NUMBER;\nBEGIN \n  \n  FOR run_counter IN 1..l_runs LOOP\n    -- Start timing\n    l_start_time := DBMS_UTILITY.GET_TIME;\n    \n    -- atribuire valori \n    DELETE FROM tip_plata  \n    WHERE  id_tip_plata NOT IN (SELECT id_tip_plata  \n                               FROM facturi) \n    RETURNING id_tip_plata, descriere BULK COLLECT INTO t; \n \n    -- End timing\n    l_end_time := DBMS_UTILITY.GET_TIME;\n    l_total_time := l_total_time + (l_end_time - l_start_time);\n    \n    DBMS_OUTPUT.PUT_LINE('Run ' || run_counter || ': ' || ((l_end_time - l_start_time)/100) || ' seconds');\n    \n    ROLLBACK; \n  END LOOP;\n  \n  l_avg_time := (l_total_time / l_runs) / 100;\n  \n  DBMS_OUTPUT.PUT_LINE('=== PERFORMANCE RESULTS ===');\n  DBMS_OUTPUT.PUT_LINE('Number of runs: ' || l_runs);\n  DBMS_OUTPUT.PUT_LINE('Average execution time: ' || l_avg_time || ' seconds');\n  DBMS_OUTPUT.PUT_LINE('Total time for all runs: ' || (l_total_time/100) || ' seconds');\n  \n  -- Show results from last run\n  DBMS_OUTPUT.PUT_LINE('Tabloul are ' || t.COUNT || ' elemente:');\n  FOR i IN t.FIRST..t.LAST LOOP \n    DBMS_OUTPUT.PUT_LINE(t(i).id ||' '|| t(i).den); \n  END LOOP; \nEND;\n/
f99a848f-66d1-49d8-b59b-1802107705cd:1763924329103:153:S:DECLARE \n  TYPE tab_ind IS TABLE OF tip_plata.descriere%TYPE \n       INDEX BY PLS_INTEGER; \n  t    tab_ind; \n  l_start_time NUMBER;\n  l_end_time NUMBER;\n  l_total_time NUMBER := 0;\n  l_runs NUMBER := 100; \n  l_avg_time NUMBER;\nBEGIN \n  \n  FOR run_counter IN 1..l_runs LOOP\n    l_start_time := DBMS_UTILITY.GET_TIME;\n    \n    DELETE FROM tip_plata \n    WHERE  id_tip_plata NOT IN (SELECT id_tip_plata FROM facturi) \n    RETURNING descriere BULK COLLECT INTO t; \n\n    l_end_time := DBMS_UTILITY.GET_TIME;\n    l_total_time := l_total_time + (l_end_time - l_start_time);\n\n    ROLLBACK; \n  END LOOP;\n  \n  l_avg_time := (l_total_time / l_runs) / 100;\n  \n  DBMS_OUTPUT.PUT_LINE('Număr teste object: ' || l_runs);\n  DBMS_OUTPUT.PUT_LINE('Timp mediu de execuție: ' || l_avg_time || ' secunde');\n  DBMS_OUTPUT.PUT_LINE('Timp total de execuție: ' || (l_total_time/100) || ' secunde');\n  \n  DBMS_OUTPUT.PUT_LINE('Tabloul are ' || t.COUNT || ' elemente:');\n  FOR i IN t.FIRST..t.LAST LOOP \n    DBMS_OUTPUT.PUT_LINE(t(i)); \n  END LOOP; \nEND;\n/
