6d30bfad-8f8b-4c2d-96ab-a441ceb5a1c6:1763926297287:0:F:UPDATE excursie_sro \nSET orase = tip_orase(orase(1), 'Bușteni', orase(2), orase(3))\nWHERE cod_excursie_sro = 1;
43b3fbad-93d6-49c7-8279-0bc167c4a21d:1763926298839:23:S:UPDATE excursie_sro e\nSET orase = (\n    SELECT CAST(MULTISET(\n        SELECT CASE \n            WHEN COLUMN_VALUE = 'Brasov' THEN 'Predeal'\n            WHEN COLUMN_VALUE = 'Predeal' THEN 'Brasov'\n            ELSE COLUMN_VALUE\n        END\n        FROM TABLE(e.orase)\n        ORDER BY ROWNUM\n    ) AS tip_orase)\n    FROM dual\n)\nWHERE cod_excursie_sro = 1;
80ee88b1-f007-4809-9320-4d190b17f769:1763926299427:15:S:UPDATE excursie_sro e\nSET orase = (\n    SELECT CAST(MULTISET(\n        SELECT COLUMN_VALUE\n        FROM TABLE(e.orase)\n        WHERE COLUMN_VALUE != 'Sinaia'\n    ) AS tip_orase)\n    FROM dual\n)\nWHERE cod_excursie_sro = 1;
54dc4e3d-a667-47ec-8dcd-2ce3d4d8e5de:1763926328550:0:F:CREATE TYPE tip_orase AS VARRAY(20) OF VARCHAR2(30);\n/
a97ecde6-ebec-47a8-918a-2fbff78ec2c6:1763926538449:0:F:UPDATE excursie_sro e\nSET orase = (\n    SELECT CAST(MULTISET(\n        SELECT column_value FROM TABLE(e.orase)\n        UNION ALL\n        SELECT 'Brașov Nou' FROM dual\n    ) AS tip_orase_sro)\n    FROM dual\n)\nWHERE cod_excursie_sro = 1;
4f2a644e-f772-4ead-b5db-99b2ac1b850f:1763926569091:0:F:UPDATE excursie_sro e\nSET orase = (\n    SELECT CAST(MULTISET(\n        SELECT CASE \n            WHEN ROWNUM = 1 THEN column_value\n            WHEN ROWNUM = 2 THEN 'Bușteni'\n            ELSE column_value\n        END\n        FROM (\n            SELECT column_value, ROWNUM as rn\n            FROM TABLE(e.orase)\n            ORDER BY ROWNUM\n        )\n        UNION ALL\n        SELECT column_value FROM (\n            SELECT column_value, ROWNUM as rn\n            FROM TABLE(e.orase)\n            ORDER BY ROWNUM\n        )\n        WHERE rn >= 2\n    ) AS tip_orase_sro)\n    FROM dual\n)\nWHERE cod_excursie_sro = 1;
f6d3976e-a01f-4a42-96d8-c9d2e981d411:1763926678711:0:F:UPDATE excursie_sro \nSET orase = tip_orase_sro('Brasov', 'Sinaia', 'Predeal', 'Brașov Nou')\nWHERE cod_excursie_sro = 1;
4f192d75-de58-400c-b66f-60d50478da2d:1763926698058:11:S:UPDATE excursie_sro \nSET orase = tip_orase('Brasov', 'Sinaia', 'Predeal', 'Brașov Nou')\nWHERE cod_excursie_sro = 1;
