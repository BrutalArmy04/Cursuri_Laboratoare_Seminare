975a13ff-e7e8-4c0e-b86e-0442e16cd487:1763836837883:2085:S:SELECT \n    tc.column_name,\n    tc.data_type,\n    tc.data_length,\n    tc.data_precision,\n    tc.data_scale,\n    tc.nullable,\n    tc.data_default,\n    cc.constraint_name,\n    cc.constraint_type\nFROM user_tab_columns tc\nLEFT JOIN user_cons_columns ucc ON tc.table_name = ucc.table_name AND tc.column_name = ucc.column_name\nLEFT JOIN user_constraints cc ON ucc.constraint_name = cc.constraint_name\nWHERE tc.table_name = 'TIP_PLATA'\nORDER BY tc.column_id;
880e17d2-2454-4641-901e-6a4f2fd852f6:1763836856404:2065:S:SELECT \n    tc.column_name,\n    tc.data_type,\n    tc.data_length,\n    tc.data_precision,\n    tc.data_scale,\n    tc.nullable,\n    tc.data_default,\n    cc.constraint_name,\n    cc.constraint_type\nFROM user_tab_columns tc\nLEFT JOIN user_cons_columns ucc ON tc.table_name = ucc.table_name AND tc.column_name = ucc.column_name\nLEFT JOIN user_constraints cc ON ucc.constraint_name = cc.constraint_name\nWHERE tc.table_name = 'FACTURI'\nORDER BY tc.column_id;
02453587-d8c9-4104-b94c-a03ef9640226:1763836878185:0:F:SELECT \n    'CREATE TABLE ' || table_name || ' (' || \n    LISTAGG(\n        column_name || ' ' || \n        data_type || \n        CASE \n            WHEN data_precision IS NOT NULL AND data_scale IS NOT NULL THEN \n                '(' || data_precision || ',' || data_scale || ')'\n            WHEN data_precision IS NOT NULL AND data_scale IS NULL THEN \n                '(' || data_precision || ')'\n            WHEN data_length IS NOT NULL AND data_type LIKE '%CHAR%' THEN \n                '(' || data_length || ')'\n            ELSE ''\n        END ||\n        CASE WHEN nullable = 'N' THEN ' NOT NULL' ELSE '' END ||\n        CASE WHEN data_default IS NOT NULL THEN ' DEFAULT ' || data_default ELSE '' END\n    , ', ') WITHIN GROUP (ORDER BY column_id) ||\n    ');' AS create_table_stmt\nFROM user_tab_columns\nWHERE table_name = 'facturi'\nGROUP BY table_name;
fb4ad7e4-1764-4ef1-983c-7ddce96de99c:1763836898654:118:S:SELECT \n    column_name,\n    data_type,\n    data_length,\n    data_precision,\n    data_scale,\n    nullable,\n    data_default\nFROM user_tab_columns\nWHERE table_name = 'facturi'\nORDER BY column_id;
18ed2f79-0dfc-42c7-8ef9-1da3ab738d4a:1763836907320:122:S:SELECT \n    column_name,\n    data_type,\n    data_length,\n    data_precision,\n    data_scale,\n    nullable,\n    data_default\nFROM user_tab_columns\nWHERE table_name = 'FACTURI'\nORDER BY column_id;
