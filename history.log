6c1ce929-5300-4f59-ae48-bd16ce115a3f:1763836986107:38:S:BEGIN\n   DBMS_METADATA.SET_TRANSFORM_PARAM(DBMS_METADATA.SESSION_TRANSFORM, 'PRETTY', TRUE);\n   DBMS_METADATA.SET_TRANSFORM_PARAM(DBMS_METADATA.SESSION_TRANSFORM, 'SQLTERMINATOR', TRUE);\nEND;\n/
ec6afabf-5749-4a81-aaf7-10265e2ebaa9:1763836986449:0:F:SELECT DBMS_METADATA.GET_DDL('TABLE', 'FACTURI') AS table_ddl\nFROM dual;
5c97becd-7ffe-4897-a2e9-b6c526c01fa1:1763837027223:0:F:DECLARE \n  TYPE rec IS RECORD (id tip_plata.id_tip_plata%TYPE, \n                      den tip_plata.descriere%TYPE); \n  TYPE tab_ind IS TABLE OF rec \n       INDEX BY PLS_INTEGER; \n  t    tab_ind; \n  start_time NUMBER;\n  end_time NUMBER;\nBEGIN \n  start_time := DBMS_UTILITY.GET_TIME;\n  \n   DELETE FROM tip_plata  \n   WHERE  id_tip_plata NOT IN (SELECT id_tip_plata  \n                               FROM facturi) \n   RETURNING id_tip_plata, descriere BULK COLLECT INTO t; \n   \n  DBMS_OUTPUT.PUT_LINE('Tabloul are ' || t.COUNT  \n         ||' elemente:'); \n  FOR i IN t.FIRST..t.LAST LOOP \n      DBMS_OUTPUT.PUT_LINE(t(i).id ||' '|| t(i).den); \n  END LOOP; \n  \n  end_time := DBMS_UTILITY.GET_TIME;\n  DBMS_OUTPUT.PUT_LINE('Execution time: ' || (end_time - start_time)/100 || ' seconds');\n  \nROLLBACK; \nEND;\n/
867c5d54-38c9-4517-89cd-993d610137f4:1763919546878:0:F:create table FACTURI_COPY as select * from FACTURI where 1=0;
