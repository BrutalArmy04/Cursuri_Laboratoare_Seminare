3638ab65-cbbb-4360-b2c5-afb81500f37a:1763836943290:0:F:SELECT \n    'CREATE TABLE FACTURI (' || CHR(10) ||\n    LISTAGG(\n        '    ' || column_name || ' ' || \n        data_type || \n        CASE \n            WHEN data_precision IS NOT NULL AND data_scale IS NOT NULL THEN \n                '(' || data_precision || ',' || data_scale || ')'\n            WHEN data_precision IS NOT NULL AND data_scale IS NULL THEN \n                '(' || data_precision || ')'\n            WHEN data_length IS NOT NULL AND data_type LIKE '%CHAR%' THEN \n                '(' || data_length || ')'\n            ELSE ''\n        END ||\n        CASE WHEN nullable = 'N' THEN ' NOT NULL' ELSE '' END ||\n        CASE WHEN data_default IS NOT NULL THEN ' DEFAULT ' || data_default ELSE '' END\n    , ',' || CHR(10)) WITHIN GROUP (ORDER BY column_id) ||\n    CHR(10) || ');' AS ddl_statement\nFROM user_tab_columns\nWHERE table_name = 'FACTURI';
