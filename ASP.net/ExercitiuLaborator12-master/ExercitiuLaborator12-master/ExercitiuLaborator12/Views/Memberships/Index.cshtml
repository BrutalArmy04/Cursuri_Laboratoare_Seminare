@model IEnumerable<ExercitiuLaborator12.Models.Membership>

<h2>Abonamente</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Message"]
    </div>
}

<table class="table">
    <thead>
        <tr>
            <th>Titlu</th>
            <th>Valoare</th>
            <th>Data emiterii</th>
            <th>Sala</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Title</td>
                <td>@m.Value</td>
                <td>@m.Date.ToShortDateString()</td>
                <td>@m.Gym?.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@m.Id">Edit</a>
                    <a asp-action="Delete" asp-route-id="@m.Id">Delete</a> 
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="New" class="btn btn-primary">Adaugă abonament</a>
